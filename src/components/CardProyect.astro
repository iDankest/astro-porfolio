---
import { Icon } from "astro-icon/components";
import ProjectCover from "./ProjectCover.astro";
import { projects } from "../data/proyects";
import { techs } from "../data/techs";

const getTech = (key: string) => (techs as any)[key] || { icon: null, name: key };

const featured = projects.find((p) => p.featured);
const rest = projects.filter((p) => !p.featured);

// Bento corto: solo los proyectos potentes. El resto vive en el carrusel "Archivo".
const bentoRest = rest.slice(0, 3); // VoicePrompt, Orbix, PrismaCrawler
const archive = rest.slice(3);

// VoicePrompt y Orbix a media fila; PrismaCrawler cierra en horizontal invertido.
const bentoSizes = ["b-3", "b-3", "b-flip"];
const bentoOf = (i: number) => bentoSizes[i] ?? "b-3";
---

<section class="projects" id="proyectos">
	<div class="projects-header">
		<div class="header-left">
			<span class="eyebrow">Selected Work · 03 / 08</span>
			<h2 class="projects-title">
				<span>Proyectos</span>
				<em>destacados</em>
			</h2>
		</div>
		<div class="header-right">
			<p class="projects-intro">
				Una selección de proyectos donde apliqué <em>front-end</em>,
				integración de <em>APIs</em> y trabajo en equipo. Cada uno con su
				propio contexto, su propio reto.
			</p>
			<div class="projects-count">
				<span class="count-num">{String(projects.length).padStart(2, "0")}</span>
				<span class="count-label">total projects</span>
			</div>
		</div>
	</div>

	<div class="projects-grid" id="projects-grid">
		{featured && (
			<article class="project-card b-featured" data-index="01">
				<div class="card-image" data-cursor="hover">
					<ProjectCover
						name={featured.name}
						tag={featured.tag}
						tagline={featured.tagline}
						cover={featured.cover}
						coverAlt={featured.coverAlt}
						kind={featured.kind}
						url={featured.url}
						github={featured.github}
						index="01"
					/>
					{featured.video ? (
						<video
							class="project-video"
							src={featured.video}
							muted
							loop
							playsinline
							preload="metadata"
						></video>
					) : null}
					<span class="featured-badge">FEATURED</span>
				</div>

				<div class="card-body">
					<div class="card-meta">
						<span class="card-tag">{featured.tag}</span>
						<ul class="card-tech">
							{featured.tech.slice(0, 4).map((t) => (
								<li class="tech-pill">
									{getTech(t).icon ? <Icon name={getTech(t).icon} class="tech-icon" /> : null}
									<span>{getTech(t).name}</span>
								</li>
							))}
						</ul>
					</div>

					<h3 class="card-title">{featured.name}</h3>
					<p class="card-desc">{featured.description}</p>

					<div class="card-actions">
						{featured.github ? (
							<a href={featured.github} target="_blank" rel="noopener" class="action-link">
								<span class="action-label">Ver código</span>
								<span class="action-icon" aria-hidden="true">
									<svg width="16" height="16" viewBox="0 0 24 24" fill="white">
										<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
									</svg>
								</span>
							</a>
						) : (
							<span class="action-note">Código privado · beta</span>
						)}
						{featured.url ? (
							<a href={featured.url} target="_blank" rel="noopener" class="action-cta">
								<span class="action-label">Live preview</span>
								<span class="cta-arrow" aria-hidden="true">
									<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M7 17L17 7"/>
										<path d="M8 7h9v9"/>
									</svg>
								</span>
							</a>
						) : (
							<span class="action-cta disabled">
								<span class="action-label">En desarrollo</span>
								<span class="cta-dot" aria-hidden="true">
									<span class="dot-pulse"></span>
								</span>
							</span>
						)}
					</div>
				</div>
			</article>
		)}

		{bentoRest.map((p, i) => {
			const indexStr = String(i + 2).padStart(2, "0");
			return (
				<article class={`project-card ${bentoOf(i)}`} data-index={indexStr}>
					<div class="card-image" data-cursor="hover">
						<ProjectCover
							name={p.name}
							tag={p.tag}
							tagline={p.tagline}
							cover={p.cover}
							coverAlt={p.coverAlt}
							kind={p.kind}
							url={p.url}
							github={p.github}
							index={indexStr}
						/>
						{p.video ? (
							<video
								class="project-video"
								src={p.video}
								muted
								loop
								playsinline
								preload="metadata"
							></video>
						) : null}
					</div>

					<div class="card-body">
						<div class="card-meta">
							<span class="card-tag">{p.tag}</span>
							<ul class="card-tech">
								{p.tech.slice(0, 4).map((t) => (
									<li class="tech-pill">
										{getTech(t).icon ? <Icon name={getTech(t).icon} class="tech-icon" /> : null}
										<span>{getTech(t).name}</span>
									</li>
								))}
							</ul>
						</div>

						<h3 class="card-title">{p.name}</h3>
						<p class="card-desc">{p.description}</p>

						<div class="card-actions">
							{p.github ? (
								<a href={p.github} target="_blank" rel="noopener" class="action-link">
									<span class="action-label">Ver código</span>
									<span class="action-icon" aria-hidden="true">
										<svg width="16" height="16" viewBox="0 0 24 24" fill="white">
											<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
										</svg>
									</span>
								</a>
							) : (
								<span class="action-note">Código privado · beta</span>
							)}
							{p.url ? (
								<a href={p.url} target="_blank" rel="noopener" class="action-cta">
									<span class="action-label">Live preview</span>
									<span class="cta-arrow" aria-hidden="true">
										<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<path d="M7 17L17 7"/>
											<path d="M8 7h9v9"/>
										</svg>
									</span>
								</a>
							) : (
								<span class="action-cta disabled">
									<span class="action-label">En desarrollo</span>
									<span class="cta-dot" aria-hidden="true">
										<span class="dot-pulse"></span>
									</span>
								</span>
							)}
						</div>
					</div>
				</article>
			);
		})}
	</div>

	{archive.length > 0 && (
		<div class="archive">
			<div class="archive-header">
				<div class="archive-title-wrap">
					<span class="eyebrow">Archivo</span>
					<h3 class="archive-title">Más <em>proyectos</em></h3>
				</div>
				<span class="archive-hint" aria-hidden="true">
					<span>drag / scroll</span>
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
				</span>
			</div>

			<div class="archive-scroller" id="archive-scroller" tabindex="0" aria-label="Carrusel de proyectos: desplázate horizontalmente">
				{archive.map((p, i) => {
					const indexStr = String(i + 2 + bentoRest.length).padStart(2, "0");
					return (
						<article class="archive-card" data-index={indexStr}>
							<div class="card-image" data-cursor="hover">
								<ProjectCover
									name={p.name}
									tag={p.tag}
									tagline={p.tagline}
									cover={p.cover}
									coverAlt={p.coverAlt}
									kind={p.kind}
									url={p.url}
									github={p.github}
									index={indexStr}
								/>
								{p.video ? (
									<video
										class="project-video"
										src={p.video}
										muted
										loop
										playsinline
										preload="metadata"
									></video>
								) : null}
							</div>
							<div class="archive-body">
								<div class="archive-meta">
									<span class="card-tag">{p.tag}</span>
									<span class="archive-num">{indexStr}</span>
								</div>
								<h4 class="archive-name">{p.name}</h4>
								<div class="archive-actions">
									{p.github ? (
										<a href={p.github} target="_blank" rel="noopener" class="archive-link">Código</a>
									) : null}
									{p.url ? (
										<a href={p.url} target="_blank" rel="noopener" class="archive-link archive-link-live">Live ↗</a>
									) : null}
								</div>
							</div>
						</article>
					);
				})}
			</div>
		</div>
	)}
</section>

<style>
	.projects {
		width: min(1280px, 100% - 3rem);
		padding: 7rem 0 4rem;
		position: relative;
		z-index: 5;
	}

	.projects-header {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
		padding-bottom: 3rem;
		border-bottom: 1px solid var(--line);
		margin-bottom: 3rem;
		align-items: end;
	}

	.projects-title {
		margin: 1.2rem 0 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(3rem, 7vw, 6rem);
		line-height: 0.9;
		letter-spacing: -0.03em;
		color: var(--text);
	}
	.projects-title span { display: block; }
	.projects-title em {
		font-style: italic;
		color: var(--acid);
		display: block;
	}

	.projects-intro {
		font-size: 0.95rem;
		line-height: 1.7;
		color: var(--text-dim);
		margin: 0 0 1.5rem;
		max-width: 38ch;
	}
	.projects-intro em {
		font-style: italic;
		color: var(--text);
	}

	.projects-count {
		display: flex;
		align-items: baseline;
		gap: 0.6rem;
		padding-top: 1rem;
		border-top: 1px solid var(--line);
	}
	.count-num {
		font-family: var(--font-display);
		font-style: italic;
		font-size: 2.4rem;
		color: var(--acid);
		line-height: 1;
	}
	.count-label {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.15em;
		color: var(--text-faint);
		text-transform: uppercase;
	}

	/* ===== Bento grid: 6 columnas, los spans dan el ritmo ===== */
	.projects-grid {
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		gap: 1.5rem;
	}

	.b-featured { grid-column: span 6; }
	.b-flip { grid-column: span 6; }
	.b-3 { grid-column: span 3; }

	.project-card {
		position: relative;
		background: var(--ink-2);
		border: 1px solid var(--line);
		display: flex;
		flex-direction: column;
		overflow: hidden;
		transition: border-color 0.4s, transform 0.4s var(--ease-out-expo), box-shadow 0.4s;
	}
	.project-card:hover {
		border-color: var(--line-strong);
		transform: translateY(-4px);
		box-shadow: 0 0 0 1px var(--acid-soft), 0 24px 48px -28px rgba(200, 255, 0, 0.18);
	}
	.project-card::before {
		content: attr(data-index);
		position: absolute;
		top: 3.2rem; /* Debajo de la barra del mockup */
		right: 1.1rem;
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.15em;
		color: var(--text-faint);
		z-index: 3;
		background: var(--ink);
		padding: 0.3rem 0.5rem;
		border: 1px solid var(--line);
	}

	/* Reveal escalonado al entrar en viewport (solo si hay JS) */
	.projects-grid.js .project-card {
		opacity: 0;
		transform: translateY(28px);
	}
	.projects-grid.js .project-card.in-view {
		opacity: 1;
		transform: translateY(0);
		transition:
			opacity 0.7s var(--ease-out-expo) var(--d, 0s),
			transform 0.7s var(--ease-out-expo) var(--d, 0s),
			border-color 0.4s, box-shadow 0.4s;
	}
	.projects-grid.js .project-card.in-view:hover {
		transform: translateY(-4px);
	}
	@media (prefers-reduced-motion: reduce) {
		.projects-grid.js .project-card {
			opacity: 1;
			transform: none;
		}
	}

	/* Featured y flip se presentan en horizontal: cover grande + cuerpo al lado */
	.b-featured,
	.b-flip {
		flex-direction: row;
	}
	.b-flip {
		flex-direction: row-reverse;
	}
	.b-featured .card-image,
	.b-flip .card-image {
		flex: 1.35;
		aspect-ratio: auto;
		min-height: 420px;
		border-bottom: none;
		border-right: 1px solid var(--line);
	}
	.b-flip .card-image {
		border-right: none;
		border-left: 1px solid var(--line);
	}
	.b-featured .card-body,
	.b-flip .card-body {
		flex: 1;
		justify-content: center;
		gap: 1.1rem;
		padding: 2.2rem 2.4rem;
	}
	.b-featured .card-title,
	.b-flip .card-title {
		font-size: clamp(2.2rem, 3.5vw, 3.2rem);
	}

	.card-image {
		position: relative;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: var(--ink);
		border-bottom: 1px solid var(--line);
	}

	/* Video on hover */
	.project-video {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0;
		transition: opacity 0.5s var(--ease-out-expo);
		z-index: 4;
		pointer-events: none;
	}
	.project-card:hover .project-video {
		opacity: 1;
	}

	.featured-badge {
		position: absolute;
		top: 3.2rem; /* Debajo de la barra del mockup */
		left: 1.1rem;
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.2em;
		color: var(--ink);
		background: var(--acid);
		padding: 0.4rem 0.7rem;
		font-weight: 600;
		z-index: 4;
	}

	.card-body {
		padding: 1.6rem 1.5rem 1.4rem;
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
		flex: 1;
	}

	.card-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.card-tag {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.1em;
		color: var(--acid);
		text-transform: uppercase;
	}

	.card-tech {
		display: flex;
		gap: 0.3rem;
		list-style: none;
		margin: 0;
		padding: 0;
		flex-wrap: wrap;
		justify-content: flex-end;
	}
	.tech-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.3rem 0.6rem;
		border: 1px solid var(--line);
		border-radius: 999px;
		font-family: var(--font-mono);
		font-size: 9.5px;
		letter-spacing: 0.05em;
		color: var(--text-dim);
		background: var(--ink);
		transition: border-color 0.3s, color 0.3s, background 0.3s;
	}
	.tech-pill:hover {
		border-color: var(--line-strong);
		color: var(--text);
	}
	.tech-icon {
		width: 13px;
		height: 13px;
		flex-shrink: 0;
		transition: transform 0.4s var(--ease-out-expo);
	}
	.tech-pill:hover .tech-icon {
		transform: scale(1.15);
	}

	.card-title {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: 1.8rem;
		line-height: 1;
		letter-spacing: -0.02em;
		color: var(--text);
	}

	.card-desc {
		margin: 0;
		font-size: 0.88rem;
		line-height: 1.6;
		color: var(--text-dim);
		flex: 1;
	}

	.card-actions {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 0.6rem;
		padding-top: 1rem;
		border-top: 1px solid var(--line);
		margin-top: 0.4rem;
		flex-wrap: wrap;
	}

	.action-link {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.1em;
		color: var(--text);
		text-transform: uppercase;
		transition: color 0.3s;
	}
	.action-link .action-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 26px;
		height: 26px;
		border: 1px solid var(--line);
		border-radius: 999px;
		color: var(--acid);
		background: var(--ink);
		transition: border-color 0.3s, transform 0.4s var(--ease-out-expo), color 0.3s;
	}
	.action-link:hover { color: var(--acid); }
	.action-link:hover .action-icon {
		border-color: var(--acid);
		transform: rotate(-12deg) scale(1.08);
	}

	.action-note {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--text-faint);
	}

	.action-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		padding: 0.55rem 0.9rem 0.55rem 1rem;
		background: var(--text);
		color: var(--ink);
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		font-weight: 500;
		transition: background 0.3s, color 0.3s, box-shadow 0.3s;
	}
	.action-cta:hover {
		background: var(--acid);
		box-shadow: 0 0 0 4px var(--acid-soft);
	}
	.action-cta.disabled {
		background: var(--ink-3);
		color: var(--text-faint);
		pointer-events: none;
		gap: 0.6rem;
	}
	.cta-arrow {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		transition: transform 0.4s var(--ease-out-expo);
	}
	.action-cta:hover .cta-arrow {
		transform: translate(2px, -2px) rotate(0deg);
	}
	.cta-dot {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 14px;
		height: 14px;
		position: relative;
	}
	.cta-dot .dot-pulse {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--ember);
		box-shadow: 0 0 0 0 var(--ember);
		animation: pulse-ember 1.8s ease-out infinite;
	}
	@keyframes pulse-ember {
		0% { box-shadow: 0 0 0 0 rgba(255, 107, 53, 0.55); }
		70% { box-shadow: 0 0 0 6px rgba(255, 107, 53, 0); }
		100% { box-shadow: 0 0 0 0 rgba(255, 107, 53, 0); }
	}

	/* ===== Archivo: carrusel horizontal con scroll-snap ===== */
	.archive {
		margin-top: 4rem;
	}

	.archive-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		gap: 1rem;
		padding-bottom: 1.2rem;
		border-bottom: 1px solid var(--line);
		margin-bottom: 1.5rem;
	}

	.archive-title {
		margin: 0.5rem 0 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(1.8rem, 3vw, 2.6rem);
		line-height: 1;
		letter-spacing: -0.02em;
		color: var(--text);
	}
	.archive-title em {
		font-style: italic;
		color: var(--acid);
	}

	.archive-hint {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--text-faint);
		animation: hint-nudge 2.4s ease-in-out infinite;
	}
	@keyframes hint-nudge {
		0%, 100% { transform: translateX(0); }
		50% { transform: translateX(6px); }
	}

	.archive-scroller {
		display: flex;
		gap: 1.25rem;
		overflow-x: auto;
		scroll-snap-type: x mandatory;
		padding: 0.25rem 0.25rem 1.25rem;
		cursor: grab;
		scrollbar-width: none;
		mask-image: linear-gradient(to right, black 94%, transparent 100%);
		-webkit-mask-image: linear-gradient(to right, black 94%, transparent 100%);
	}
	.archive-scroller::-webkit-scrollbar { display: none; }
	.archive-scroller {
		user-select: none;
		-webkit-user-select: none;
	}
	.archive-scroller :global(img) {
		-webkit-user-drag: none;
		user-select: none;
	}
	.archive-scroller.dragging {
		cursor: grabbing;
		scroll-snap-type: none;
	}
	.archive-scroller:focus-visible {
		outline: 1px solid var(--acid);
		outline-offset: 4px;
	}

	.archive-card {
		position: relative;
		flex: 0 0 min(380px, 82vw);
		scroll-snap-align: start;
		background: var(--ink-2);
		border: 1px solid var(--line);
		display: flex;
		flex-direction: column;
		overflow: hidden;
		transition: border-color 0.4s, transform 0.4s var(--ease-out-expo), box-shadow 0.4s;
	}
	.archive-card:hover {
		border-color: var(--line-strong);
		transform: translateY(-4px);
		box-shadow: 0 0 0 1px var(--acid-soft), 0 24px 48px -28px rgba(200, 255, 0, 0.18);
	}
	.archive-card .card-image {
		aspect-ratio: 16 / 10;
	}
	/* En el carrusel las cards no llevan numerito flotante sobre la imagen */
	.archive-card::before { display: none; }

	.archive-body {
		padding: 1.1rem 1.2rem 1.2rem;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.archive-meta {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
	}

	.archive-num {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.15em;
		color: var(--text-faint);
	}

	.archive-name {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: 1.45rem;
		line-height: 1;
		letter-spacing: -0.02em;
		color: var(--text);
	}

	.archive-actions {
		display: flex;
		gap: 1rem;
		padding-top: 0.6rem;
		border-top: 1px solid var(--line);
		margin-top: 0.3rem;
	}

	.archive-link {
		font-family: var(--font-mono);
		font-size: 10.5px;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--text-dim);
		transition: color 0.3s;
	}
	.archive-link:hover { color: var(--acid); }
	.archive-link-live { color: var(--acid); }
	.archive-link-live:hover { color: var(--text); }

	@media (prefers-reduced-motion: reduce) {
		.archive-hint { animation: none; }
	}

	@media (max-width: 1100px) {
		.projects-grid { grid-template-columns: 1fr 1fr; }
		.b-featured, .b-flip { grid-column: span 2; }
		.b-3 { grid-column: span 1; }
		.b-featured, .b-flip { flex-direction: column; }
		.b-featured .card-image, .b-flip .card-image {
			aspect-ratio: 16 / 9;
			min-height: 0;
			border-right: none;
			border-left: none;
			border-bottom: 1px solid var(--line);
		}
	}

	@media (max-width: 900px) {
		.projects-header { grid-template-columns: 1fr; gap: 1.5rem; }
		.project-card::before, .featured-badge {
			top: 3.2rem; /* Mantenerlo bajo la barra del mockup también en móvil */
		}
	}

	@media (max-width: 640px) {
		.projects-grid { grid-template-columns: 1fr; }
		.b-featured, .b-flip, .b-3 { grid-column: span 1; }
	}
</style>

<script>
	// Auto-play video al hacer hover (bento y carrusel)
	document.querySelectorAll(".project-card, .archive-card").forEach((card) => {
		const video = card.querySelector(".project-video") as HTMLVideoElement | null;
		if (!video) return;
		card.addEventListener("mouseenter", () => {
			video.play().catch(() => {});
		});
		card.addEventListener("mouseleave", () => {
			video.pause();
			video.currentTime = 0;
		});
	});

	// Carrusel del archivo: drag-to-scroll con el ratón (en táctil el scroll nativo ya funciona)
	const scroller = document.getElementById("archive-scroller");
	if (scroller) {
		let isDown = false;
		let startX = 0;
		let startScroll = 0;
		let moved = false;

		scroller.addEventListener("pointerdown", (e) => {
			if (e.pointerType !== "mouse") return;
			e.preventDefault(); // evita que el drag nativo de las imágenes secuestre el gesto
			isDown = true;
			moved = false;
			startX = e.clientX;
			startScroll = scroller.scrollLeft;
			scroller.setPointerCapture(e.pointerId);
			scroller.classList.add("dragging");
		});
		scroller.addEventListener("pointermove", (e) => {
			if (!isDown) return;
			const dx = e.clientX - startX;
			if (Math.abs(dx) > 4) moved = true;
			scroller.scrollLeft = startScroll - dx;
		});
		scroller.addEventListener("pointerup", (e) => {
			if (!isDown) return;
			isDown = false;
			scroller.releasePointerCapture(e.pointerId);
			scroller.classList.remove("dragging");
		});
		scroller.addEventListener("pointercancel", () => {
			isDown = false;
			scroller.classList.remove("dragging");
		});
		// Evita que un drag dispare el click de los enlaces
		scroller.addEventListener("click", (e) => {
			if (moved) {
				e.preventDefault();
				e.stopPropagation();
				moved = false;
			}
		}, true);
	}

	// Reveal escalonado al entrar en viewport
	const grid = document.getElementById("projects-grid");
	if (grid && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
		grid.classList.add("js");
		const cards = [...grid.querySelectorAll(".project-card")];
		const io = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (!entry.isIntersecting) return;
					const el = entry.target as HTMLElement;
					// Delay escalonado dentro del lote visible
					const visibleIdx = cards.indexOf(el) % 4;
					el.style.setProperty("--d", `${visibleIdx * 0.08}s`);
					el.classList.add("in-view");
					io.unobserve(el);
				});
			},
			{ rootMargin: "0px 0px -8% 0px", threshold: 0.1 }
		);
		cards.forEach((c) => io.observe(c));
	}
</script>
