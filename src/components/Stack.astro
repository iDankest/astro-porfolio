---
import { Icon } from 'astro-icon/components';

const stack = [
	{ name: "HTML5", icon: "devicon:html5" },
	{ name: "CSS3", icon: "devicon:css3" },
	{ name: "JavaScript", icon: "devicon:javascript" },
	{ name: "Vue.js", icon: "devicon:vuejs" },
	{ name: "Tailwind", icon: "devicon:tailwindcss" },
	{ name: "PHP", icon: "devicon:php" },
	{ name: "Symfony", icon: "devicon:symfony" },
	{ name: "MySQL", icon: "devicon:mysql" },
	{ name: "Git", icon: "devicon:git" },
	{ name: "Astro", icon: "devicon:astro" },
];
---

<section class="stack">
	<div class="stack-header">
		<span class="eyebrow">Stack · 01 / 10</span>
		<span class="stack-meta">Languages, frameworks & tools I work with</span>
	</div>

	<div class="marquee">
		<div class="marquee-track">
			{[...stack, ...stack].map((tech) => (
				<div class="stack-item">
					<Icon name={tech.icon} class="stack-icon" />
					<span>{tech.name}</span>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.stack {
		width: 100%;
		padding: 5rem 0 1.5rem;
		position: relative;
		z-index: 5;
	}

	.stack-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		width: min(1280px, 100% - 3rem);
		margin: 0 auto 2.5rem;
		padding-bottom: 1rem;
		border-bottom: 1px solid var(--line);
	}

	.stack-meta {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.1em;
		color: var(--text-faint);
	}

	.marquee {
		overflow: hidden;
		padding: 0.5rem 0;
		mask-image: linear-gradient(
			to right,
			transparent 0%,
			black 8%,
			black 92%,
			transparent 100%
		);
		-webkit-mask-image: linear-gradient(
			to right,
			transparent 0%,
			black 8%,
			black 92%,
			transparent 100%
		);
	}

	.marquee:hover .marquee-track {
		animation-play-state: paused;
	}

	.stack-item {
		display: inline-flex;
		align-items: center;
		gap: 0.8rem;
		padding: 0 2.5rem;
		font-family: var(--font-sans);
		font-size: clamp(1.8rem, 3vw, 2.6rem);
		font-weight: 300;
		letter-spacing: -0.02em;
		color: var(--text);
		white-space: nowrap;
		transition: color 0.3s;
	}

	.stack-item:hover { color: var(--acid); }

	.stack-icon {
		width: 2.2rem;
		height: 2.2rem;
		flex-shrink: 0;
		transition: transform 0.4s var(--ease-out-expo);
	}

	.stack-item:hover .stack-icon {
		transform: scale(1.15) rotate(-4deg);
	}

	@media (max-width: 700px) {
		.stack-header { flex-direction: column; gap: 0.5rem; align-items: flex-start; }
		.stack-item { padding: 0 1.5rem; }
	}
</style>
