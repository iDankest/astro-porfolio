---
const videos = [
	{
		title: "Orbix en acción",
		project: "Orbix",
		tagline: "Datos espaciales con IA y animaciones fluidas",
		// video: "/videos/orbix-demo.mp4",  // TODO: añadir video cuando esté listo
		// poster: "/videos/orbix-poster.jpg",
		duration: "0:30",
		emoji: "\u{1F680}",
	},
	{
		title: "PrismaCrawler gameplay",
		project: "PrismaCrawler",
		tagline: "Roguelike full-stack con Phaser y Prisma",
		// video: "/videos/prismacrawler-demo.mp4",
		// poster: "/videos/prismacrawler-poster.jpg",
		duration: "1:15",
		emoji: "\u{1F3AE}",
	},
	{
		title: "Tu Guitarra Online",
		project: "Tu Guitarra Online",
		tagline: "E-commerce con Vue 3 y localStorage",
		// video: "/videos/guitarra-demo.mp4",
		// poster: "/videos/guitarra-poster.jpg",
		duration: "0:20",
		emoji: "\u{1F3B8}",
	},
	{
		title: "GalaGame",
		project: "GalaGame",
		tagline: "Shoot 'em up espacial en vanilla JS",
		// video: "/videos/galagame-demo.mp4",
		// poster: "/videos/galagame-poster.jpg",
		duration: "0:45",
		emoji: "\u{1F680}",
	},
];
---

<section class="videos" id="videos">
	<div class="videos-header">
		<span class="eyebrow">Motion · 04 / 10</span>
		<h2 class="videos-title">
			<span>Videos</span>
			<em>en acción</em>
		</h2>
		<p class="videos-intro">
			Demos cortas de mis proyectos: interacciones reales, animaciones y
			flujos completos. Pasa el ratón o toca para reproducir.
		</p>
	</div>

	<div class="videos-grid">
		{videos.map((v) => (
			<article class="video-card">
				<div class="video-frame">
					{v.video ? (
						<video
							class="video-el"
							src={v.video}
							poster={v.poster}
							muted
							loop
							playsinline
							preload="metadata"
						></video>
					) : (
						<div class="video-placeholder">
							<div class="placeholder-emoji">{v.emoji}</div>
							<div class="placeholder-label">Video pendiente</div>
						</div>
					)}
					<button class="play-overlay" data-cursor="hover" aria-label="Reproducir">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
							<path d="M8 5v14l11-7z"/>
						</svg>
					</button>
					<span class="video-duration">{v.duration}</span>
				</div>
				<div class="video-body">
					<span class="video-project">{v.project}</span>
					<h3 class="video-title">{v.title}</h3>
					<p class="video-tagline">{v.tagline}</p>
				</div>
			</article>
		))}
	</div>
</section>

<style>
	.videos {
		width: min(1280px, 100% - 3rem);
		padding: 7rem 0 4rem;
		position: relative;
		z-index: 5;
	}

	.videos-header {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
		padding-bottom: 3rem;
		border-bottom: 1px solid var(--line);
		margin-bottom: 3rem;
		align-items: end;
	}

	.videos-title {
		margin: 1.2rem 0 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(3rem, 7vw, 6rem);
		line-height: 0.9;
		letter-spacing: -0.03em;
		color: var(--text);
	}

	.videos-title span { display: block; }
	.videos-title em {
		font-style: italic;
		color: var(--acid);
		display: block;
	}

	.videos-intro {
		font-size: 0.95rem;
		line-height: 1.7;
		color: var(--text-dim);
		margin: 0;
		max-width: 38ch;
	}

	.videos-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
	}

	.video-card {
		background: var(--ink-2);
		border: 1px solid var(--line);
		display: flex;
		flex-direction: column;
		overflow: hidden;
		transition: border-color 0.4s, transform 0.4s var(--ease-out-expo);
	}

	.video-card:hover {
		border-color: var(--line-strong);
		transform: translateY(-4px);
	}

	.video-frame {
		position: relative;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: var(--ink);
		border-bottom: 1px solid var(--line);
	}

	.video-el {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.video-placeholder {
		width: 100%;
		height: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1rem;
		background:
			linear-gradient(135deg, var(--ink-2), var(--ink)),
			repeating-linear-gradient(
				45deg,
				transparent,
				transparent 20px,
				rgba(200, 255, 0, 0.03) 20px,
				rgba(200, 255, 0, 0.03) 40px
			);
	}

	.placeholder-emoji {
		font-size: 3.5rem;
		filter: grayscale(0.3);
		opacity: 0.7;
	}

	.placeholder-label {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.2em;
		color: var(--text-faint);
		text-transform: uppercase;
	}

	.play-overlay {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(10, 10, 12, 0.4);
		opacity: 0;
		transition: opacity 0.4s var(--ease-out-expo), background 0.4s;
		border: none;
		cursor: pointer;
		color: var(--acid);
	}

	.video-card:hover .play-overlay {
		opacity: 1;
		background: rgba(10, 10, 12, 0.2);
	}

	.play-overlay svg {
		width: 56px;
		height: 56px;
		padding: 14px;
		border: 1px solid var(--acid);
		border-radius: 50%;
		background: var(--ink);
		filter: drop-shadow(0 0 20px var(--acid));
		transition: transform 0.4s var(--ease-out-expo);
	}

	.video-card:hover .play-overlay svg {
		transform: scale(1.1);
	}

	.video-duration {
		position: absolute;
		bottom: 0.8rem;
		right: 0.8rem;
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.1em;
		color: var(--text);
		background: var(--ink);
		padding: 0.3rem 0.5rem;
		border: 1px solid var(--line);
	}

	.video-body {
		padding: 1.6rem 1.5rem 1.4rem;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.video-project {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.15em;
		color: var(--acid);
		text-transform: uppercase;
	}

	.video-title {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: 1.4rem;
		line-height: 1.1;
		letter-spacing: -0.01em;
		color: var(--text);
	}

	.video-tagline {
		margin: 0;
		font-size: 0.85rem;
		line-height: 1.5;
		color: var(--text-dim);
	}

	@media (max-width: 900px) {
		.videos-header { grid-template-columns: 1fr; gap: 1.5rem; }
		.videos-grid { grid-template-columns: 1fr; }
	}
</style>

<script>
	// Auto-play videos on hover when they have a real src
	document.querySelectorAll('.video-card').forEach((card) => {
		const video = card.querySelector('.video-el') as HTMLVideoElement | null;
		const overlay = card.querySelector('.play-overlay');
		if (!video || !overlay) return;

		const play = () => video.play().catch(() => {});
		const pause = () => { video.pause(); video.currentTime = 0; };

		card.addEventListener('mouseenter', play);
		card.addEventListener('mouseleave', pause);
		overlay.addEventListener('click', () => {
			if (video.paused) play(); else pause();
		});
	});
</script>
