---
import type { Post } from "../../lib/reader";
import { blogCategories } from "../../data/blog-categories";

interface Props {
	post: Post;
	/** Forma de la tarjeta dentro del bento. */
	variant?: "default" | "wide" | "featured";
}

const { post, variant = "default" } = Astro.props;
const { slug, entry } = post;

const date = entry.publishedDate
	? new Date(entry.publishedDate).toLocaleDateString("es-ES", {
			year: "numeric",
			month: "long",
			day: "numeric",
		})
	: "";

const category = entry.category ?? "otros";
const sectionLabel =
	blogCategories.find((c) => c.value === category)?.label ?? "Blog";
---

<article class="post-card" data-category={category} data-variant={variant}>
	<a class="post-card-link" href={`/blog/${slug}`} data-cursor="hover">
		<div class="post-card-art">
			<img
				src={`/blog/og/${slug}.png`}
				alt={entry.title}
				width="1200"
				height="630"
				loading="lazy"
				decoding="async"
			/>
		</div>
		<div class="post-card-body">
			<div class="post-card-meta">
				<span class="post-card-tag">{sectionLabel}</span>
				{date && (
					<time class="post-card-date" datetime={entry.publishedDate}>{date}</time>
				)}
			</div>
			<h3 class="post-card-title" style={`view-transition-name: vt-post-${slug}`}>{entry.title}</h3>
			<p class="post-card-desc">{entry.description}</p>
			<span class="post-card-cta">
				Leer artículo
				<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M5 12h14M13 6l6 6-6 6" />
				</svg>
			</span>
		</div>
	</a>
</article>

<style>
	.post-card {
		background: var(--ink-2);
		border: 1px solid var(--line);
		overflow: hidden;
		transition: border-color 0.4s, transform 0.4s var(--ease-out-expo), box-shadow 0.4s;
		height: 100%;
	}
	.post-card:hover {
		border-color: var(--line-strong);
		transform: translateY(-4px);
		box-shadow: 0 0 0 1px var(--acid-soft), 0 24px 48px -28px rgba(0, 0, 0, 0.55);
	}

	.post-card-link {
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.post-card-art {
		position: relative;
		aspect-ratio: 1200 / 630;
		overflow: hidden;
		border-bottom: 1px solid var(--line);
		background: var(--ink);
	}
	.post-card-art img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.6s var(--ease-out-expo);
	}
	.post-card:hover .post-card-art img {
		transform: scale(1.05);
	}

	.post-card-body {
		padding: 1.4rem 1.5rem 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
		flex: 1;
	}

	.post-card-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.post-card-tag {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.1em;
		color: var(--acid);
		text-transform: uppercase;
	}
	.post-card-date {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.05em;
		color: var(--text-faint);
	}

	.post-card-title {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: 1.7rem;
		line-height: 1.04;
		letter-spacing: -0.02em;
		color: var(--text);
	}

	.post-card-desc {
		margin: 0;
		font-size: 0.88rem;
		line-height: 1.6;
		color: var(--text-dim);
		flex: 1;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-card-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--text);
		padding-top: 0.85rem;
		margin-top: 0.1rem;
		border-top: 1px solid var(--line);
		transition: color 0.3s;
	}
	.post-card-cta svg {
		transition: transform 0.4s var(--ease-out-expo);
	}
	.post-card:hover .post-card-cta {
		color: var(--acid);
	}
	.post-card:hover .post-card-cta svg {
		transform: translateX(4px);
	}

	/* ===== Variante WIDE: arte a la izquierda, texto a la derecha ===== */
	.post-card[data-variant="wide"] .post-card-link {
		flex-direction: row;
	}
	.post-card[data-variant="wide"] .post-card-art {
		aspect-ratio: auto;
		flex: 0 0 42%;
		border-bottom: none;
		border-right: 1px solid var(--line);
	}
	.post-card[data-variant="wide"] .post-card-body {
		flex: 1;
		justify-content: center;
	}

	/* ===== Variante FEATURED: arte grande a la derecha, texto a la izquierda ===== */
	.post-card[data-variant="featured"] .post-card-link {
		flex-direction: row-reverse;
	}
	.post-card[data-variant="featured"] .post-card-art {
		aspect-ratio: auto;
		flex: 0 0 46%;
		border-bottom: none;
		border-left: 1px solid var(--line);
	}
	.post-card[data-variant="featured"] .post-card-body {
		flex: 1;
		justify-content: center;
		padding: 2.4rem 2.4rem 2.4rem;
		gap: 1.1rem;
	}
	.post-card[data-variant="featured"] .post-card-title {
		font-size: clamp(2rem, 3.2vw, 3rem);
		line-height: 0.98;
	}
	.post-card[data-variant="featured"] .post-card-desc {
		font-size: 1rem;
		-webkit-line-clamp: 4;
	}
	.post-card[data-variant="featured"] .post-card-tag {
		font-size: 11px;
	}

	/* ===== Responsive: por debajo de 720px todo vuelve a vertical ===== */
	@media (max-width: 720px) {
		.post-card[data-variant="wide"] .post-card-link,
		.post-card[data-variant="featured"] .post-card-link {
			flex-direction: column;
		}
		.post-card[data-variant="wide"] .post-card-art,
		.post-card[data-variant="featured"] .post-card-art {
			aspect-ratio: 16 / 10;
			flex: none;
			border-right: none;
			border-left: none;
			border-bottom: 1px solid var(--line);
		}
		.post-card[data-variant="featured"] .post-card-body {
			padding: 1.4rem 1.5rem 1.5rem;
			gap: 0.8rem;
		}
		.post-card[data-variant="featured"] .post-card-title {
			font-size: 2rem;
		}
	}
</style>
