---
// Contenedor tipográfico del artículo. El contenido se inyecta vía slot
// (lo renderiza el DocumentRenderer de Keystatic) y se estiliza con :global.
---

<div class="prose"><slot /></div>

<style>
	.prose {
		font-family: var(--font-sans);
		font-size: 1.06rem;
		line-height: 1.75;
		color: var(--text);
		max-width: 68ch;
	}

	.prose :global(h2),
	.prose :global(h3) {
		scroll-margin-top: 6rem;
	}

	.prose :global(p) {
		margin: 0 0 1.4rem;
		color: var(--text);
	}

	.prose :global(h2) {
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(1.7rem, 3.5vw, 2.4rem);
		line-height: 1.05;
		letter-spacing: -0.02em;
		color: var(--text);
		margin: 2.6rem 0 1rem;
	}
	.prose :global(h3) {
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(1.4rem, 3vw, 1.8rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		color: var(--text);
		margin: 2rem 0 0.8rem;
	}

	.prose :global(a) {
		color: var(--acid);
		text-decoration: none;
		border-bottom: 1px solid var(--acid-soft);
		transition: border-color 0.3s;
	}
	.prose :global(a:hover) {
		border-color: var(--acid);
	}

	.prose :global(strong) {
		color: var(--text);
		font-weight: 600;
	}
	.prose :global(em) {
		font-style: italic;
	}

	.prose :global(ul),
	.prose :global(ol) {
		margin: 0 0 1.4rem;
		padding-left: 1.4rem;
		color: var(--text);
	}
	.prose :global(li) {
		margin: 0.4rem 0;
	}
	.prose :global(li::marker) {
		color: var(--acid);
	}

	.prose :global(blockquote) {
		margin: 1.8rem 0;
		padding: 0.6rem 0 0.6rem 1.4rem;
		border-left: 2px solid var(--acid);
		color: var(--text-dim);
		font-style: italic;
		font-family: var(--font-display);
		font-size: 1.3rem;
		line-height: 1.5;
	}

	.prose :global(code) {
		font-family: var(--font-mono);
		font-size: 0.85em;
		background: var(--ink-3);
		border: 1px solid var(--line);
		border-radius: 4px;
		padding: 0.12em 0.4em;
		color: var(--rust);
	}
	.prose :global(pre) {
		margin: 1.6rem 0;
		padding: 1.2rem 1.3rem;
		background: var(--ink-2);
		border: 1px solid var(--line);
		border-radius: 8px;
		overflow-x: auto;
	}
	.prose :global(pre code) {
		background: none;
		border: none;
		padding: 0;
		color: var(--text);
		font-size: 0.85rem;
		line-height: 1.6;
	}

	.prose :global(img) {
		max-width: 100%;
		height: auto;
		border: 1px solid var(--line);
		border-radius: 8px;
		margin: 1.6rem 0;
	}

	.prose :global(hr) {
		border: none;
		border-top: 1px solid var(--line);
		margin: 2.4rem 0;
	}

	.prose :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin: 1.6rem 0;
		font-size: 0.95rem;
	}
	.prose :global(th),
	.prose :global(td) {
		border: 1px solid var(--line);
		padding: 0.6rem 0.8rem;
		text-align: left;
	}
	.prose :global(th) {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--text-dim);
		background: var(--ink-2);
	}
</style>
