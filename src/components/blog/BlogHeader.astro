---
import { Image } from "astro:assets";
import { resolveCover } from "../../lib/covers";

interface Props {
	title: string;
	date?: string | null;
	tags?: readonly string[];
	cover?: string | null;
	coverAlt?: string | null;
}

const { title, date, tags = [], cover, coverAlt } = Astro.props;

const formattedDate = date
	? new Date(date).toLocaleDateString("es-ES", {
			year: "numeric",
			month: "long",
			day: "numeric",
		})
	: "";

const coverImg = resolveCover(cover);
---

<header class="post-header">
	<nav class="breadcrumb" aria-label="Migas de pan">
		<a href="/">Inicio</a>
		<span aria-hidden="true">/</span>
		<a href="/blog">Blog</a>
	</nav>

	{tags.length > 0 && (
		<ul class="post-tags">
			{tags.map((t) => (
				<li class="post-tag">{t}</li>
			))}
		</ul>
	)}

	<h1 class="post-title">{title}</h1>

	{formattedDate && (
		<div class="post-meta">
			<time datetime={date}>{formattedDate}</time>
			<span aria-hidden="true">·</span>
			<span>Kilian Sánchez</span>
		</div>
	)}

	{coverImg && (
		<div class="post-cover">
			<Image
				src={coverImg}
				alt={coverAlt || title}
				widths={[800, 1200]}
				sizes="(max-width: 820px) 100vw, 760px"
				loading="eager"
			/>
		</div>
	)}
</header>

<style>
	.post-header {
		display: flex;
		flex-direction: column;
		gap: 1.1rem;
		padding-bottom: 2rem;
		margin-bottom: 2.5rem;
		border-bottom: 1px solid var(--line);
	}

	.breadcrumb {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-faint);
	}
	.breadcrumb a {
		color: var(--text-dim);
		transition: color 0.3s;
	}
	.breadcrumb a:hover {
		color: var(--acid);
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.post-tag {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--acid);
		border: 1px solid var(--line);
		border-radius: 999px;
		padding: 0.3rem 0.7rem;
		background: var(--ink);
	}

	.post-title {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(2.4rem, 6vw, 4.2rem);
		line-height: 0.98;
		letter-spacing: -0.025em;
		color: var(--text);
	}

	.post-meta {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-family: var(--font-mono);
		font-size: 12px;
		letter-spacing: 0.05em;
		color: var(--text-dim);
	}

	.post-cover {
		margin-top: 1rem;
		border: 1px solid var(--line);
		overflow: hidden;
		aspect-ratio: 1200 / 630;
	}
	.post-cover img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
</style>
