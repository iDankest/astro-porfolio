---
import ArticleCard from "./ArticleCard.astro";
import { getPublishedPosts } from "../../lib/reader";

const posts = (await getPublishedPosts()).slice(0, 3);
---

{posts.length > 0 && (
	<section class="blog-section" id="blog">
		<div class="blog-section-header">
			<div class="blog-section-head-left">
				<span class="eyebrow">Blog · Últimas notas</span>
				<h2 class="blog-section-title">
					<span>Desde el</span>
					<em>blog</em>
				</h2>
			</div>
			<a href="/blog" class="blog-section-all" data-cursor="hover">
				Ver todos los artículos
				<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M5 12h14M13 6l6 6-6 6" />
				</svg>
			</a>
		</div>

		<div class="blog-section-grid">
			{posts.map((post) => (
				<ArticleCard post={post} />
			))}
		</div>
	</section>
)}

<style>
	.blog-section {
		width: min(1280px, 100% - 3rem);
		margin: 0 auto;
		padding: 5rem 0 4rem;
		position: relative;
		z-index: 5;
	}

	.blog-section-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		gap: 2rem;
		padding-bottom: 2.5rem;
		margin-bottom: 2.5rem;
		border-bottom: 1px solid var(--line);
		flex-wrap: wrap;
	}

	.blog-section-title {
		margin: 1rem 0 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(2.5rem, 6vw, 5rem);
		line-height: 0.9;
		letter-spacing: -0.03em;
		color: var(--text);
	}
	.blog-section-title span {
		display: block;
	}
	.blog-section-title em {
		font-style: italic;
		color: var(--acid);
		display: block;
	}

	.blog-section-all {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--text);
		padding-bottom: 0.5rem;
		border-bottom: 1px solid var(--line-strong);
		transition: color 0.3s, border-color 0.3s;
	}
	.blog-section-all svg {
		transition: transform 0.4s var(--ease-out-expo);
	}
	.blog-section-all:hover {
		color: var(--acid);
		border-color: var(--acid);
	}
	.blog-section-all:hover svg {
		transform: translateX(4px);
	}

	.blog-section-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}

	@media (max-width: 980px) {
		.blog-section-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (max-width: 640px) {
		.blog-section-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
