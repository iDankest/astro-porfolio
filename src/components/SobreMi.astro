---
const socials = [
	{ href: "https://www.canva.com/design/DAGBi4AizY4/SWyFJnvqjXieGiF--ubLig/view", label: "CV", target: "_blank" },
	{ href: "https://github.com/idankest", label: "GitHub", target: "_blank" },
	{ href: "https://www.linkedin.com/in/dankest/", label: "LinkedIn", target: "_blank" },
];
---

<section class="hero" id="inicio">
	<div class="hero-grid">
		<div class="hero-meta">
			<div class="meta-row reveal">
				<span class="meta-key">Index</span>
				<span class="meta-value">/00</span>
			</div>
			<div class="meta-row reveal reveal-delay-1">
				<span class="meta-key">Status</span>
				<span class="meta-value status">
					<span class="status-dot"></span>
					Disponible para trabajar
				</span>
			</div>
			<div class="meta-row reveal reveal-delay-2">
				<span class="meta-key">Based in</span>
				<span class="meta-value">Canarias, España · UTC+0</span>
			</div>
		</div>

		<div class="hero-headline">
			<h1 class="hero-name">
				<span class="name-line name-1">
					<span class="name-word reveal">Kilian</span>
				</span>
				<span class="name-line name-2">
					<span class="name-word name-italic reveal reveal-delay-2">Sánchez</span>
					<span class="name-cursor reveal reveal-delay-4">_</span>
				</span>
			</h1>
			<div class="hero-role reveal reveal-delay-3">
				<span class="role-bracket">[</span>
				<span class="role-text">Desarrollador Web · Front-End</span>
				<span class="role-bracket">]</span>
			</div>
		</div>

		<div class="hero-portrait reveal reveal-delay-3">
			<div class="portrait-frame">
				<img src="/assets/Fotodeprefil.png" alt="Kilian Sánchez" />
				<div class="portrait-stamp">
					<span>EST.</span>
					<span>2023</span>
				</div>
			</div>
			<div class="portrait-tags">
				<span class="tag">HTML</span>
				<span class="tag">CSS</span>
				<span class="tag">JS</span>
				<span class="tag">Vue.js</span>
				<span class="tag">Tailwind</span>
				<span class="tag">PHP</span>
			</div>
		</div>

		<div class="hero-bio reveal reveal-delay-4">
			<p class="bio-lead">
				<span class="bio-drop">A</span>pasionado del <em>Front-End</em>, construyendo interfaces que se sienten tan bien como se ven.
			</p>
			<p class="bio-body">
				Mi enfoque está en los detalles: tipografía, movimiento, jerarquía. Gracias a una base sólida en
				<em>Front-End</em> y conocimientos prácticos de <em>Back-End</em>, puedo llevar una idea desde
				el boceto hasta producción — limpio, mantenible y con intención.
			</p>
			<div class="hero-socials">
				{socials.map((s) => (
					<a href={s.href} target={s.target} rel="noopener" class="social">
						<span>{s.label}</span>
						<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M17 7H8M17 7V16"/></svg>
					</a>
				))}
			</div>
		</div>
	</div>

	<div class="hero-scroll reveal reveal-delay-5">
		<span class="scroll-text">scroll</span>
		<div class="scroll-line"><div class="scroll-dot"></div></div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		width: min(1280px, 100% - 3rem);
		padding: 9rem 0 4rem;
		z-index: 5;
	}

	.hero-grid {
		display: grid;
		grid-template-columns: 1.6fr 1fr;
		grid-template-rows: auto auto;
		gap: 1.5rem 3rem;
		grid-template-areas:
			"meta    portrait"
			"headline portrait"
			"bio     bio";
	}

	.hero-meta {
		grid-area: meta;
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
		padding-top: 0.4rem;
	}

	.meta-row {
		display: flex;
		align-items: center;
		gap: 0.8rem;
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.1em;
	}

	.meta-key {
		min-width: 5.5rem;
		color: var(--text-faint);
		text-transform: uppercase;
	}

	.meta-value { color: var(--text); }

	.status {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--acid);
	}

	.status-dot {
		display: inline-block;
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--acid);
		animation: pulse-acid 2.2s ease-in-out infinite;
	}

	.hero-headline {
		grid-area: headline;
		display: flex;
		flex-direction: column;
		gap: 1.4rem;
	}

	.hero-name {
		margin: 0;
		font-weight: 400;
		line-height: 0.86;
		letter-spacing: -0.04em;
	}

	.name-line {
		display: block;
		overflow: hidden;
	}

	.name-word {
		display: inline-block;
		font-family: var(--font-display);
		font-size: clamp(4.5rem, 13vw, 12.5rem);
		letter-spacing: -0.04em;
		color: var(--text);
	}

	.name-italic {
		font-style: italic;
		color: var(--text);
	}

	.name-2 .name-italic { color: var(--text); }

	.name-cursor {
		display: inline-block;
		font-family: var(--font-mono);
		font-weight: 400;
		color: var(--acid);
		font-size: 0.7em;
		vertical-align: 0.18em;
		margin-left: 0.05em;
		animation: blink 1.05s steps(1) infinite;
	}

	.hero-role {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		font-family: var(--font-mono);
		font-size: 13px;
		letter-spacing: 0.08em;
		color: var(--text-dim);
	}

	.role-bracket { color: var(--acid); }

	.hero-portrait {
		grid-area: portrait;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		align-items: flex-end;
	}

	.portrait-frame {
		position: relative;
		width: clamp(220px, 22vw, 320px);
		aspect-ratio: 3 / 4;
		border: 1px solid var(--line);
		background: var(--ink-2);
		overflow: hidden;
		transition: transform 0.6s var(--ease-out-expo);
	}

	.portrait-frame:hover { transform: translateY(-4px); }

	.portrait-frame::before {
		content: "";
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, transparent 60%, rgba(10, 10, 12, 0.4));
		z-index: 1;
		pointer-events: none;
	}

	.portrait-frame img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: grayscale(0.15) contrast(1.05);
		transition: filter 0.6s, transform 0.6s var(--ease-out-expo);
	}

	.portrait-frame:hover img {
		filter: grayscale(0) contrast(1.08);
		transform: scale(1.04);
	}

	.portrait-stamp {
		position: absolute;
		top: 0.7rem;
		left: 0.7rem;
		display: flex;
		gap: 0.4rem;
		font-family: var(--font-mono);
		font-size: 9.5px;
		letter-spacing: 0.18em;
		color: var(--text);
		background: var(--ink);
		padding: 0.3rem 0.5rem;
		border: 1px solid var(--line);
		z-index: 2;
	}

	.portrait-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.3rem;
		max-width: clamp(220px, 22vw, 320px);
		justify-content: flex-end;
	}

	.tag {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.1em;
		padding: 0.3rem 0.55rem;
		border: 1px solid var(--line);
		border-radius: 999px;
		color: var(--text-dim);
		text-transform: uppercase;
	}

	.hero-bio {
		grid-area: bio;
		max-width: 64ch;
		margin-top: 1rem;
		padding-top: 2rem;
		border-top: 1px solid var(--line);
	}

	.bio-lead {
		font-family: var(--font-display);
		font-style: italic;
		font-size: clamp(1.4rem, 2.2vw, 1.9rem);
		line-height: 1.25;
		color: var(--text);
		margin: 0 0 1.2rem;
		letter-spacing: -0.01em;
	}

	.bio-drop {
		font-family: var(--font-display);
		font-size: 1.4em;
		line-height: 0.7;
		float: left;
		padding: 0.05em 0.12em 0 0;
		color: var(--acid);
	}

	.bio-body {
		font-size: 0.98rem;
		line-height: 1.7;
		color: var(--text-dim);
		margin: 0 0 2rem;
		max-width: 56ch;
	}

	.bio-body em, .bio-lead em {
		font-style: italic;
		color: var(--text);
	}

	.hero-socials {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.social {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.7rem 1.1rem;
		border: 1px solid var(--line);
		border-radius: 999px;
		font-family: var(--font-mono);
		font-size: 12px;
		letter-spacing: 0.06em;
		color: var(--text);
		transition: all 0.3s var(--ease-out-expo);
		background: transparent;
	}

	.social:hover {
		background: var(--text);
		color: var(--ink);
		border-color: var(--text);
		transform: translateY(-2px);
	}

	.hero-scroll {
		display: flex;
		align-items: center;
		gap: 0.8rem;
		margin-top: 4rem;
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.2em;
		color: var(--text-faint);
		text-transform: uppercase;
	}

	.scroll-line {
		position: relative;
		width: 80px;
		height: 1px;
		background: var(--line);
		overflow: hidden;
	}

	.scroll-dot {
		position: absolute;
		left: 0;
		top: -1px;
		width: 16px;
		height: 3px;
		background: var(--acid);
		animation: scroll-dot 2.4s var(--ease-in-out-quart) infinite;
	}

	@keyframes scroll-dot {
		0% { left: -16px; }
		50% { left: 100%; }
		100% { left: 100%; }
	}

	@media (max-width: 900px) {
		.hero { padding-top: 7rem; }
		.hero-grid {
			grid-template-columns: 1fr;
			grid-template-areas:
				"meta"
				"headline"
				"portrait"
				"bio";
			gap: 2.5rem;
		}
		.hero-portrait { align-items: flex-start; }
		.hero-name .name-word { font-size: clamp(4rem, 18vw, 8rem); }
		.portrait-frame { width: min(280px, 80vw); }
		.portrait-tags { max-width: min(280px, 80vw); justify-content: flex-start; }
	}
</style>
