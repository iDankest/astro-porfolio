---
const exp = [
	{
		img: "/assets/0x0.png",
		empresa: "iServices",
		cargo: "Técnico en reparaciones y ventas",
		periodo: "Dic 2025 — Mar 2026",
		descripcion: "Reparación de dispositivos móviles, diagnóstico y atención al cliente.",
		tareas: ["Diagnósticos", "Reparaciones", "Atención al cliente"],
	},
	{
		img: "/assets/islas.jpg",
		empresa: "ISLASSEM",
		cargo: "Desarrollador Web",
		periodo: "Ago 2024 — Sep 2024",
		descripcion: "Mantenimiento de páginas web, políticas de cookies y protección de datos.",
		tareas: ["WordPress", "Protección de datos", "Cookies"],
	},
	{
		img: "/assets/bitbox_it_logo.jpg",
		empresa: "BitBox S.L",
		cargo: "Técnico IT",
		periodo: "Mar 2019 — Nov 2019",
		descripcion: "Mantenimiento de equipos informáticos y soporte HelpDesk.",
		tareas: ["Instalación de sistemas", "HelpDesk", "Mantenimiento de racks"],
	},
];

const edu = [
	{
		img: "/assets/ironhack_logo.jpeg",
		centro: "Ironhack",
		titulo: "Desarrollo Web Full Stack + IA",
		periodo: "2026 — En curso",
		descripcion: "Bootcamp en colaboración con la FULP: 3 meses de formación intensiva + 6 de prácticas en empresa.",
		tareas: ["IA aplicada", "Full Stack", "Prácticas en empresa"],
	},
	{
		img: "/assets/42malaga.jpg",
		centro: "42 Málaga",
		titulo: "Piscina · Escuela de Elite de Programación",
		periodo: "Oct 2025 — Nov 2025",
		descripcion: "Inmersión intensiva: trabajo en equipo, C, y aprender a aprender.",
		tareas: ["C", "Aprendí a aprender", "Trabajo en equipo"],
	},
	{
		img: "/assets/Reboot.png",
		centro: "Reboot Academy",
		titulo: "Bootcamp E-commerce",
		periodo: "Ago 2024 — Feb 2025",
		descripcion: "Creación de tiendas online: front, back y plataformas e-commerce.",
		tareas: ["HTML, CSS, JS", "PHP, Symfony, Tailwind", "MySQL, Git, Docker", "WordPress, WooCommerce, Prestashop, Magento"],
	},
	{
		img: "/assets/f2000.jpg",
		centro: "Fuerteventura 2000",
		titulo: "Desarrollador de Aplicaciones Web",
		periodo: "Mar 2023 — Feb 2024",
		descripcion: "Formación profesional en desarrollo de aplicaciones web full-stack.",
		tareas: ["HTML, CSS, JS", "Angular, Node.js, Express.js", "MySQL, MongoDB, Git"],
	},
];
---

<section class="exp" id="experiencia">
	<div class="exp-header">
		<span class="eyebrow">Trayectoria · 04 / 08</span>
		<h2 class="exp-title">
			<span>Experiencia</span>
			<em>& formación</em>
		</h2>
	</div>

	<div class="timeline">
		<div class="timeline-block">
			<div class="block-label">
				<span class="block-num">A.</span>
				<h3>Experiencia Profesional</h3>
			</div>
			<div class="timeline-list">
				{exp.map((e, i) => (
					<div class="entry" style={`--i:${i}`}>
						<div class="entry-marker">
							<span class="entry-year">{e.periodo}</span>
						</div>
						<div class="entry-content">
							<div class="entry-text">
								<h4 class="entry-title">{e.empresa}</h4>
								<span class="entry-role">{e.cargo}</span>
								<p class="entry-desc">{e.descripcion}</p>
								<ul class="entry-tasks">
									{e.tareas.map((t) => <li>{t}</li>)}
								</ul>
							</div>
							<img class="entry-img" src={e.img} alt={e.empresa} loading="lazy" />
						</div>
					</div>
				))}
			</div>
		</div>

		<div class="timeline-block">
			<div class="block-label">
				<span class="block-num">B.</span>
				<h3>Formación Académica</h3>
			</div>
			<div class="timeline-list">
				{edu.map((e, i) => (
					<div class="entry" style={`--i:${i}`}>
						<div class="entry-marker">
							<span class="entry-year">{e.periodo}</span>
						</div>
						<div class="entry-content">
							<div class="entry-text">
								<h4 class="entry-title">{e.centro}</h4>
								<span class="entry-role">{e.titulo}</span>
								<p class="entry-desc">{e.descripcion}</p>
								<ul class="entry-tasks">
									{e.tareas.map((t) => <li>{t}</li>)}
								</ul>
							</div>
							<img class="entry-img" src={e.img} alt={e.centro} loading="lazy" />
						</div>
					</div>
				))}
			</div>
		</div>
	</div>
</section>

<style>
	.exp {
		width: min(1280px, 100% - 3rem);
		padding: 7rem 0 4rem;
		position: relative;
		z-index: 5;
	}

	.exp-header {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding-bottom: 3rem;
		border-bottom: 1px solid var(--line);
		margin-bottom: 4rem;
	}

	.exp-title {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(3rem, 7vw, 6rem);
		line-height: 0.9;
		letter-spacing: -0.03em;
		color: var(--text);
	}

	.exp-title span { display: block; }
	.exp-title em {
		font-style: italic;
		color: var(--acid);
		display: block;
	}

	.timeline {
		display: flex;
		flex-direction: column;
		gap: 5rem;
	}

	.timeline-block {
		display: grid;
		grid-template-columns: 1fr 2.5fr;
		gap: 3rem;
	}

	.block-label {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding-top: 0.5rem;
		position: sticky;
		top: 7rem;
		height: max-content;
	}

	.block-num {
		font-family: var(--font-display);
		font-style: italic;
		font-size: 2.5rem;
		color: var(--acid);
		line-height: 1;
	}

	.block-label h3 {
		margin: 0;
		font-family: var(--font-sans);
		font-size: 0.85rem;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--text-dim);
	}

	.timeline-list {
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	.entry {
		display: grid;
		grid-template-columns: 8rem 1fr;
		gap: 1.5rem;
		padding-bottom: 3rem;
		border-bottom: 1px solid var(--line);
	}

	.entry:last-child { border-bottom: none; padding-bottom: 0; }

	.entry-marker {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.entry-year {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.1em;
		color: var(--text);
		padding-left: 1rem;
		position: relative;
	}

	.entry-year::before {
		content: "";
		position: absolute;
		left: 0;
		top: 0.4em;
		width: 0.5rem;
		height: 1px;
		background: var(--acid);
	}

	.entry-content {
		display: grid;
		grid-template-columns: 1fr 140px;
		gap: 1.5rem;
		align-items: start;
	}

	.entry-text {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.entry-text .entry-desc { margin-top: 0.4rem; }
	.entry-text .entry-tasks { margin-top: 0.5rem; }

	.entry-img {
		width: 140px;
		min-width: 140px;
		aspect-ratio: 1;
		object-fit: cover;
		border: 1px solid var(--line);
		filter: grayscale(0.3);
		transition: filter 0.4s var(--ease-out-expo), transform 0.4s var(--ease-out-expo), border-color 0.4s;
		flex-shrink: 0;
		border-radius: 6px;
		display: block;
	}

	.entry:hover .entry-img {
		filter: grayscale(0);
		transform: scale(1.05);
		border-color: var(--acid);
	}

	.entry-title {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: 1.6rem;
		line-height: 1.05;
		letter-spacing: -0.02em;
		color: var(--text);
	}

	.entry-role {
		font-style: italic;
		font-family: var(--font-display);
		color: var(--text-dim);
		font-size: 1.05rem;
	}

	.entry-desc {
		margin: 0;
		font-size: 0.92rem;
		line-height: 1.6;
		color: var(--text-dim);
		max-width: 60ch;
	}

	.entry-tasks {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.entry-tasks li {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.08em;
		padding: 0.3rem 0.6rem;
		border: 1px solid var(--line);
		border-radius: 999px;
		color: var(--text-dim);
		text-transform: uppercase;
	}

	.entry-tasks li:hover {
		border-color: var(--acid);
		color: var(--acid);
	}

	@media (max-width: 900px) {
		.timeline-block { grid-template-columns: 1fr; gap: 1.5rem; }
		.block-label { position: static; flex-direction: row; align-items: center; gap: 1rem; }
		.entry { grid-template-columns: 1fr; gap: 0.5rem; }
		.entry-marker { padding-bottom: 0.5rem; border-bottom: 1px solid var(--line); }
		.entry-content {
			display: grid;
			grid-template-columns: 96px 1fr;
			gap: 1.1rem;
			align-items: start;
		}
		.entry-img {
			order: -1;
			width: 96px;
			min-width: 96px;
			height: 96px;
			min-height: 96px;
			aspect-ratio: 1;
			border-radius: 8px;
			object-fit: contain;
			background: var(--ink-2);
			padding: 8px;
		}
	}

	@media (max-width: 400px) {
		.entry-content { grid-template-columns: 72px 1fr; gap: 0.9rem; }
		.entry-img { width: 72px; min-width: 72px; height: 72px; min-height: 72px; }
	}
</style>
