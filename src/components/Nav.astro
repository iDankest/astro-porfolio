---
const links = [
	{ href: "#inicio", label: "Inicio", num: "01" },
	{ href: "#proyectos", label: "Proyectos", num: "02" },
	{ href: "#experiencia", label: "Trayectoria", num: "03" },
	{ href: "#certificados", label: "Certificados", num: "04" },
	{ href: "#resenas", label: "Reseñas", num: "05" },
	{ href: "#faq", label: "FAQ", num: "06" },
	{ href: "#contacto", label: "Contacto", num: "07" },
];
---

<nav class="nav-floating">
	<div class="nav-inner">
		<a href="#inicio" class="nav-mark" aria-label="Inicio">
			<span class="mark-bracket">[</span>
			<span class="mark-name">K.S</span>
			<span class="mark-bracket">]</span>
		</a>
		<ul class="nav-links">
			{links.map((l) => (
				<li>
					<a href={l.href} class="nav-link">
						<span class="nav-num">{l.num}</span>
						<span class="nav-label">{l.label}</span>
					</a>
				</li>
			))}
		</ul>
		<a href="https://github.com/idankest" target="_blank" rel="noopener" class="nav-cta">
			<span>github</span>
			<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7V16"/></svg>
		</a>
		<button
			type="button"
			class="nav-burger"
			id="nav-burger"
			aria-label="Abrir menú"
			aria-expanded="false"
			aria-controls="nav-mobile"
		>
			<span class="burger-line"></span>
			<span class="burger-line"></span>
		</button>
	</div>

	<div class="nav-mobile" id="nav-mobile" hidden>
		<ul class="nav-mobile-links">
			{links.map((l) => (
				<li>
					<a href={l.href} class="nav-mobile-link">
						<span class="nav-num">{l.num}</span>
						<span class="nav-label">{l.label}</span>
					</a>
				</li>
			))}
		</ul>
	</div>
</nav>

<style>
	.nav-floating {
		position: fixed;
		top: 1.25rem;
		left: 50%;
		transform: translateX(-50%);
		z-index: 100;
		width: min(1100px, calc(100% - 2rem));
		pointer-events: none;
	}

	.nav-inner {
		pointer-events: auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.5rem 0.6rem 0.5rem 1rem;
		background: rgba(19, 19, 24, 0.72);
		backdrop-filter: blur(20px) saturate(180%);
		-webkit-backdrop-filter: blur(20px) saturate(180%);
		border: 1px solid var(--line);
		border-radius: 999px;
		box-shadow: 0 1px 0 rgba(255, 255, 255, 0.03) inset, 0 20px 40px -20px rgba(0, 0, 0, 0.6);
	}

	.nav-mark {
		display: inline-flex;
		align-items: baseline;
		gap: 0.15rem;
		font-family: var(--font-mono);
		font-size: 13px;
		font-weight: 500;
		color: var(--text);
		letter-spacing: 0.04em;
		padding: 0.35rem 0.6rem;
	}
	.mark-bracket { color: var(--acid); }
	.mark-name { color: var(--text); }

	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.15rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.nav-link {
		position: relative;
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.45rem 0.85rem;
		border-radius: 999px;
		font-size: 13px;
		font-weight: 450;
		color: var(--text-dim);
		transition: color 0.25s, background 0.25s;
	}

	.nav-link:hover {
		color: var(--text);
		background: rgba(255, 255, 255, 0.04);
	}

	.nav-num {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.1em;
		color: var(--text-faint);
	}

	.nav-link:hover .nav-num { color: var(--acid); }

	.nav-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.5rem 0.95rem;
		border-radius: 999px;
		background: var(--text);
		color: var(--ink);
		font-family: var(--font-mono);
		font-size: 12px;
		font-weight: 500;
		letter-spacing: 0.04em;
		transition: background 0.25s, transform 0.25s;
	}
	.nav-cta:hover {
		background: var(--acid);
		transform: translateY(-1px);
	}

	/* ===== Menú móvil ===== */
	.nav-burger {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		width: 38px;
		height: 38px;
		padding: 0;
		background: transparent;
		border: 1px solid var(--line);
		border-radius: 999px;
		align-items: center;
		transition: border-color 0.3s;
	}
	.nav-burger:hover { border-color: var(--line-strong); }
	.burger-line {
		display: block;
		width: 14px;
		height: 1.5px;
		background: var(--text);
		transition: transform 0.3s var(--ease-out-expo), opacity 0.3s;
	}
	.nav-burger[aria-expanded="true"] .burger-line:first-child {
		transform: translateY(3.25px) rotate(45deg);
	}
	.nav-burger[aria-expanded="true"] .burger-line:last-child {
		transform: translateY(-3.25px) rotate(-45deg);
	}

	.nav-mobile {
		display: none;
		pointer-events: auto;
		margin-top: 0.6rem;
		background: rgba(19, 19, 24, 0.92);
		backdrop-filter: blur(20px) saturate(180%);
		-webkit-backdrop-filter: blur(20px) saturate(180%);
		border: 1px solid var(--line);
		border-radius: 20px;
		overflow: hidden;
		box-shadow: 0 1px 0 rgba(255, 255, 255, 0.03) inset, 0 20px 40px -20px rgba(0, 0, 0, 0.6);
	}
	.nav-mobile:not([hidden]) { display: block; }

	.nav-mobile-links {
		list-style: none;
		margin: 0;
		padding: 0.5rem;
		display: flex;
		flex-direction: column;
	}
	.nav-mobile-link {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		padding: 0.8rem 1rem;
		border-radius: 12px;
		font-size: 15px;
		color: var(--text-dim);
		transition: color 0.25s, background 0.25s;
	}
	.nav-mobile-link:hover,
	.nav-mobile-link:focus-visible {
		color: var(--text);
		background: rgba(255, 255, 255, 0.04);
	}
	.nav-mobile-link .nav-num { min-width: 1.4rem; }

	@media (max-width: 820px) {
		.nav-links { display: none; }
		.nav-inner { padding: 0.4rem 0.4rem 0.4rem 0.7rem; }
		.nav-burger { display: flex; }
	}

	@media (min-width: 821px) {
		.nav-mobile { display: none !important; }
	}
</style>

<script>
	const burger = document.getElementById('nav-burger');
	const mobileMenu = document.getElementById('nav-mobile');

	const setOpen = (open: boolean) => {
		if (!burger || !mobileMenu) return;
		burger.setAttribute('aria-expanded', String(open));
		burger.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
		mobileMenu.hidden = !open;
	};

	if (burger && mobileMenu) {
		burger.addEventListener('click', () => {
			setOpen(burger.getAttribute('aria-expanded') !== 'true');
		});

		// Cerrar al navegar a una sección
		mobileMenu.querySelectorAll('a').forEach((a) => {
			a.addEventListener('click', () => setOpen(false));
		});

		// Cerrar con Escape
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && burger.getAttribute('aria-expanded') === 'true') {
				setOpen(false);
				burger.focus();
			}
		});

		// Cerrar al hacer click fuera del nav
		document.addEventListener('click', (e) => {
			if (
				burger.getAttribute('aria-expanded') === 'true' &&
				e.target instanceof Node &&
				!burger.closest('nav')?.contains(e.target)
			) {
				setOpen(false);
			}
		});
	}
</script>
