---
import { Image, getImage } from 'astro:assets';

interface Props {
	name: string;
	tag: string;
	tagline: string;
	cover: ImageMetadata;
	coverAlt?: string;
	index: string;
	kind?: 'web' | 'app';
	url?: string;
	github?: string;
}

const { name, tag, tagline, cover, coverAlt, index, kind = 'web', url, github } = Astro.props;

// Dirección real que se muestra en la barra del mockup (solo para webs).
const address = url
	? new URL(url).hostname
	: github
		? github.replace(/^https?:\/\//, '')
		: name.toLowerCase().replace(/\s+/g, '-');

// Genera una versión minúscula y muy comprimida que sirve como LQIP (low-quality image placeholder).
const lqip = await getImage({
	src: cover,
	width: 16,
	quality: 30,
	format: 'webp',
});
---

<div class="project-cover" style={`background-image:url('${lqip.src}')`}>
	<div class="browser-mockup">
		<div class="browser-bar">
			<div class="browser-dots">
				<span class="dot dot-red"></span>
				<span class="dot dot-yellow"></span>
				<span class="dot dot-green"></span>
			</div>
			{kind === 'app' ? (
				<div class="app-titlebar">
					<span>{name}</span>
					<span class="app-badge">macOS</span>
				</div>
			) : (
				<div class="browser-address">
					<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="lock-icon" aria-hidden="true">
						<rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
						<path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
					</svg>
					<span>{address}</span>
				</div>
			)}
			<div class="browser-action-placeholder"></div>
		</div>

		<div class="browser-viewport">
			<Image
				src={cover}
				alt={coverAlt ?? name}
				widths={[480, 800, 1200]}
				sizes="(max-width: 900px) 100vw, 50vw"
				quality={70}
				loading="lazy"
				decoding="async"
				format="webp"
				class="cover-img"
			/>
		</div>
	</div>
</div>

<style>
	.project-cover {
		position: relative;
		width: 100%;
		height: 100%;
		overflow: hidden;
		background-color: var(--ink);
		background-size: cover;
		background-position: center;
		isolation: isolate;
	}

	/* Capa de blur encima del LQIP para que parezca un placeholder suave */
	.project-cover::after {
		content: "";
		position: absolute;
		inset: 0;
		backdrop-filter: blur(20px) saturate(1.4);
		-webkit-backdrop-filter: blur(20px) saturate(1.4);
		z-index: 0;
	}

	.browser-mockup {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		z-index: 1;
		background: rgba(10, 10, 12, 0.4);
	}

	.browser-bar {
		height: 36px;
		background: rgba(19, 19, 24, 0.85);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--line);
		display: grid;
		grid-template-columns: 80px 1fr 80px;
		align-items: center;
		padding: 0 1rem;
		z-index: 5;
	}

	.browser-dots {
		display: flex;
		gap: 6px;
	}

	.dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		opacity: 0.85;
	}

	.dot-red { background: #ff5f56; }
	.dot-yellow { background: #ffbd2e; }
	.dot-green { background: #27c93f; }

	.browser-address {
		background: rgba(10, 10, 12, 0.6);
		border: 1px solid var(--line);
		border-radius: 6px;
		height: 22px;
		font-family: var(--font-mono);
		font-size: 10px;
		color: var(--text-dim);
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 6px;
		padding: 0 0.85rem;
		max-width: 260px;
		margin: 0 auto;
		width: 100%;
		overflow: hidden;
	}

	.browser-address span {
		min-width: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.lock-icon {
		color: var(--acid);
		opacity: 0.85;
		flex-shrink: 0;
	}

	/* Barra de título para apps nativas (sin dirección ni candado) */
	.app-titlebar {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.6rem;
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.08em;
		color: var(--text-dim);
	}

	.app-badge {
		font-size: 8.5px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--acid);
		border: 1px solid var(--acid-soft);
		background: var(--acid-soft);
		border-radius: 999px;
		padding: 0.15rem 0.5rem;
	}

	.browser-viewport {
		flex: 1;
		position: relative;
		overflow: hidden;
	}

	.cover-img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: top;
		filter: grayscale(0.2) contrast(1.02) brightness(0.9);
		transition: object-position 5s ease-in-out, filter 0.6s, transform 0.8s var(--ease-out-expo), opacity 0.6s;
		opacity: 0;
		z-index: 1;
	}

	.cover-img[data-astro-cid][loading="lazy"]:not([src]) {
		opacity: 0;
	}

	/* Cuando la imagen termina de cargar, se muestra con un fade-in */
	.cover-img[loading="lazy"].is-loaded,
	.cover-img:not([loading="lazy"]) {
		opacity: 1;
	}

	/* Cuando pasamos el cursor por la tarjeta completa (.project-card) */
	:global(.project-card:hover) .cover-img {
		filter: grayscale(0) contrast(1.05) brightness(1.05);
		object-position: bottom;
		transform: scale(1.03);
	}
</style>

<script>
	// Cuando cada imagen termina de cargar, le añadimos la clase para hacer fade-in.
	document.querySelectorAll('.cover-img').forEach((img) => {
		const htmlImg = img as HTMLImageElement;
		if (htmlImg.complete) {
			htmlImg.classList.add('is-loaded');
		} else {
			htmlImg.addEventListener('load', () => htmlImg.classList.add('is-loaded'), { once: true });
		}
	});
</script>
