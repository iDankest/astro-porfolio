---
const year = new Date().getFullYear();
---

<footer class="footer">
	<div class="footer-inner">
		<div class="footer-top">
			<div class="footer-mark">
				<span class="footer-mark-bracket">[</span>
				<span class="footer-mark-name">Kilian Sánchez</span>
				<span class="footer-mark-bracket">]</span>
			</div>
			<div class="footer-meta">
				<span class="eyebrow">© {year} · Hecho con</span>
				<span class="heart">♥</span>
				<span class="eyebrow">y</span>
				<a href="https://astro.build" target="_blank" rel="noopener" class="footer-astro">Astro</a>
			</div>
		</div>

		<div class="footer-bottom">
			<span class="footer-tag">
				<span class="status-dot"></span>
				Actualmente disponible para nuevos proyectos
			</span>
			<a href="#inicio" class="back-top">
				<span>Volver arriba</span>
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
			</a>
		</div>
	</div>
</footer>

<style>
	.footer {
		width: 100%;
		padding: 2rem 1.5rem 2.5rem;
		border-top: 1px solid var(--line);
		margin-top: 4rem;
		background: var(--ink);
		position: relative;
		z-index: 5;
	}

	.footer-inner {
		width: min(1280px, 100%);
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.footer-top {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.footer-mark {
		font-family: var(--font-mono);
		font-size: 13px;
		letter-spacing: 0.05em;
	}

	.footer-mark-bracket { color: var(--acid); }
	.footer-mark-name { color: var(--text); margin: 0 0.3rem; }

	.footer-meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.heart {
		color: var(--ember);
		font-size: 14px;
		animation: float-y 2.2s ease-in-out infinite;
	}

	.footer-astro {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--acid);
		border-bottom: 1px solid currentColor;
		padding-bottom: 1px;
	}

	.footer-bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		padding-top: 1.2rem;
		border-top: 1px solid var(--line);
		flex-wrap: wrap;
	}

	.footer-tag {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.08em;
		color: var(--text-dim);
	}

	.status-dot {
		width: 6px;
		height: 6px;
		background: var(--acid);
		border-radius: 50%;
		animation: pulse-acid 2.2s ease-in-out infinite;
	}

	.back-top {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--text-dim);
		transition: color 0.3s;
	}

	.back-top:hover { color: var(--acid); }
</style>
