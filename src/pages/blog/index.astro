---
export const prerender = true;

import Layout from "../../layouts/Layout.astro";
import BlogNav from "../../components/blog/BlogNav.astro";
import Footer from "../../components/Footer.astro";
import ArticleCard from "../../components/blog/ArticleCard.astro";
import { getPublishedPosts } from "../../lib/reader";
import { blogCategories } from "../../data/blog-categories";
import "../../styles/global.css";

const posts = await getPublishedPosts();

// Reparto del bento: el primero es el destacado (2×2); del resto, cada tercero
// es ancho (2×1) y los demás son cuadrados (1×1). Da un mosaico asimétrico.
type Variant = "featured" | "wide" | "default";
const tiles = posts.map((post, i) => {
	if (i === 0) return { post, variant: "featured" as Variant, size: "featured" };
	const j = i - 1;
	const wide = j % 3 === 2;
	return {
		post,
		variant: (wide ? "wide" : "default") as Variant,
		size: wide ? "wide" : "sm",
	};
});

const usedCategories = new Set(posts.map((p) => p.entry.category ?? "otros"));
const catCount = usedCategories.size;
---

<Layout
	title="Blog — Kilian Sánchez"
	description="Artículos sobre desarrollo web front-end, Astro, rendimiento y SEO técnico. Notas de lo que aprendo construyendo interfaces."
>
	<BlogNav />

	<main class="blog-index" id="inicio">
		<header class="blog-hero">
			<span class="eyebrow">Blog · Notas de desarrollo</span>
			<h1 class="blog-title">
				<span>Escribo sobre</span>
				<em>front-end</em>
			</h1>
			<p class="blog-intro">
				Desarrollo web, rendimiento y <em>SEO técnico</em>. Lo que voy
				aprendiendo construyendo interfaces rápidas y bien posicionadas.
			</p>
			{posts.length > 0 && (
				<p class="blog-stat">
					<span>{posts.length} artículos</span>
					<span aria-hidden="true">·</span>
					<span>{catCount} secciones</span>
				</p>
			)}
		</header>

		{posts.length === 0 ? (
			<p class="blog-empty">Pronto publicaré el primer artículo. Vuelve dentro de poco.</p>
		) : (
			<>
				<div class="blog-filters" id="blogFilters" aria-label="Filtrar por sección">
					<button class="blog-chip is-active" data-cat="all" type="button">Todos</button>
					{blogCategories
						.filter((c) => usedCategories.has(c.value))
						.map((c) => (
							<button class="blog-chip" data-cat={c.value} type="button">{c.label}</button>
						))}
				</div>

				<div class="blog-bento" id="blogGrid">
					{tiles.map((t) => (
						<div class={`bento-tile tile--${t.size}`}>
							<ArticleCard post={t.post} variant={t.variant} />
						</div>
					))}
				</div>

				<p class="blog-empty-filter" id="blogEmptyFilter" hidden>
					Todavía no hay artículos en esta sección.
				</p>
			</>
		)}
	</main>

	<Footer />
</Layout>

<style>
	.blog-index {
		width: min(1280px, 100% - 3rem);
		margin: 0 auto;
		padding: 9rem 0 4rem;
		position: relative;
		z-index: 5;
	}

	.blog-hero {
		display: flex;
		flex-direction: column;
		gap: 1.2rem;
		padding-bottom: 3rem;
		margin-bottom: 3rem;
		border-bottom: 1px solid var(--line);
	}

	.blog-title {
		margin: 0.6rem 0 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(3rem, 8vw, 6rem);
		line-height: 0.9;
		letter-spacing: -0.03em;
		color: var(--text);
	}
	.blog-title span { display: block; }
	.blog-title em {
		font-style: italic;
		color: var(--acid);
		display: block;
	}

	.blog-intro {
		font-size: 1rem;
		line-height: 1.7;
		color: var(--text-dim);
		margin: 0;
		max-width: 48ch;
	}
	.blog-intro em {
		font-style: italic;
		color: var(--text);
	}

	.blog-stat {
		display: flex;
		gap: 0.7rem;
		margin: 0.2rem 0 0;
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-faint);
	}

	/* ===== Bento ===== */
	.blog-bento {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		grid-auto-flow: dense;
		gap: 1.25rem;
	}
	.bento-tile {
		min-width: 0;
	}
	.tile--featured {
		grid-column: span 2;
		grid-row: span 2;
	}
	.tile--wide {
		grid-column: span 2;
	}
	.tile--sm {
		grid-column: span 1;
	}
	.bento-tile[hidden] { display: none; }

	.blog-empty {
		font-family: var(--font-mono);
		font-size: 0.95rem;
		color: var(--text-dim);
	}

	/* ===== Filtros ===== */
	.blog-filters {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 2rem;
	}
	.blog-chip {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--text-dim);
		background: var(--ink-2);
		border: 1px solid var(--line);
		border-radius: 999px;
		padding: 0.45rem 0.95rem;
		transition: color 0.25s, border-color 0.25s, background 0.25s;
	}
	.blog-chip:hover {
		color: var(--text);
		border-color: var(--line-strong);
	}
	.blog-chip.is-active {
		color: var(--ink);
		background: var(--acid);
		border-color: var(--acid);
	}

	.blog-empty-filter {
		font-family: var(--font-mono);
		font-size: 0.95rem;
		color: var(--text-dim);
		padding: 2rem 0;
	}

	/* ===== Responsive ===== */
	@media (max-width: 980px) {
		.blog-bento {
			grid-template-columns: repeat(2, 1fr);
		}
		.tile--featured {
			grid-column: span 2;
			grid-row: span 1;
		}
		.tile--wide {
			grid-column: span 2;
		}
	}

	@media (max-width: 640px) {
		.blog-index {
			padding: 6.5rem 0 3rem;
		}
		.blog-hero {
			padding-bottom: 2rem;
			margin-bottom: 2rem;
		}
		.blog-bento {
			grid-template-columns: 1fr;
		}
		.tile--featured,
		.tile--wide,
		.tile--sm {
			grid-column: span 1;
			grid-row: span 1;
		}
	}
</style>

<script>
	import { isMotionOn } from "../../lib/prefs";

	const grid = document.getElementById("blogGrid");
	const filters = document.getElementById("blogFilters");
	const emptyFilter = document.getElementById("blogEmptyFilter");

	if (grid && filters) {
		const chips = Array.from(filters.querySelectorAll<HTMLElement>(".blog-chip"));
		const tiles = Array.from(grid.querySelectorAll<HTMLElement>(".bento-tile"));
		const cardCat = (tile: HTMLElement) =>
			tile.querySelector<HTMLElement>(".post-card")?.dataset.category ?? "otros";

		const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
		const motion = isMotionOn() && !reduce;

		// GSAP solo se carga si el usuario quiere animaciones. Si no, las tarjetas
		// se quedan visibles tal cual (cero JS de animación, CWV intactos).
		type GsapMod = typeof import("gsap");
		let gsap: GsapMod["gsap"] | null = null;

		const showVisible = (els: HTMLElement[]) => {
			if (gsap) {
				gsap.to(els, {
					opacity: 1,
					y: 0,
					duration: 0.5,
					stagger: 0.06,
					ease: "power3.out",
					overwrite: true,
				});
			}
		};

		const apply = (cat: string, animate = false) => {
			const c = cat || "all";
			const visible: HTMLElement[] = [];
			tiles.forEach((tile) => {
				const match = c === "all" || cardCat(tile) === c;
				tile.hidden = !match;
				if (match) visible.push(tile);
			});
			chips.forEach((chip) =>
				chip.classList.toggle("is-active", chip.dataset.cat === c),
			);
			if (emptyFilter) emptyFilter.hidden = visible.length !== 0;
			if (animate) showVisible(visible);
		};

		const fromHash = () => apply(location.hash.slice(1) || "all");

		chips.forEach((chip) => {
			chip.addEventListener("click", () => {
				const cat = chip.dataset.cat || "all";
				history.replaceState(
					null,
					"",
					cat === "all" ? location.pathname : `#${cat}`,
				);
				apply(cat, true);
			});
		});

		window.addEventListener("hashchange", fromHash);
		fromHash();

		// --- Animación de entrada con GSAP (diferida) ---
		if (motion) {
			(async () => {
				const mod = await import("gsap");
				const stMod = await import("gsap/ScrollTrigger");
				gsap = mod.gsap;
				const ScrollTrigger = stMod.ScrollTrigger;
				gsap.registerPlugin(ScrollTrigger);

				const visibleTiles = tiles.filter((t) => !t.hidden);
				gsap.set(visibleTiles, { opacity: 0, y: 40 });

				ScrollTrigger.batch(visibleTiles, {
					start: "top 90%",
					once: true,
					onEnter: (batch) =>
						gsap!.to(batch, {
							opacity: 1,
							y: 0,
							duration: 0.7,
							stagger: 0.09,
							ease: "power3.out",
							overwrite: true,
						}),
				});

				// Parallax sutil del arte del destacado para dar profundidad.
				const featuredArt = grid.querySelector<HTMLElement>(
					'.tile--featured .cover-art-svg',
				);
				if (featuredArt) {
					gsap.to(featuredArt, {
						yPercent: 8,
						ease: "none",
						scrollTrigger: {
							trigger: featuredArt.closest(".tile--featured"),
							start: "top bottom",
							end: "bottom top",
							scrub: true,
						},
					});
				}

				ScrollTrigger.refresh();
			})();
		}
	}
</script>
