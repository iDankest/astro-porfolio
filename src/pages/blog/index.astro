---
export const prerender = true;

import Layout from "../../layouts/Layout.astro";
import BlogNav from "../../components/blog/BlogNav.astro";
import Footer from "../../components/Footer.astro";
import CategoryTile from "../../components/blog/CategoryTile.astro";
import { getPublishedPosts } from "../../lib/reader";
import { blogCategories } from "../../data/blog-categories";
import "../../styles/global.css";

const posts = await getPublishedPosts();

// El índice es un bento de CATEGORÍAS a pantalla completa. Cada panel navega a su
// página real (/blog/seccion/<cat>) con una transición nativa. No muta al publicar.
const categoriesWithPosts = blogCategories
	.map((c) => ({
		...c,
		count: posts.filter((p) => (p.entry.category ?? "otros") === c.value).length,
	}))
	.filter((c) => c.count > 0);

const bento = [
	{ cat: "all", label: "Todos", count: posts.length, featured: true },
	...categoriesWithPosts.map((c) => ({
		cat: c.value,
		label: c.label,
		count: c.count,
		featured: false,
	})),
];
---

<Layout
	title="Blog — Kilian Sánchez"
	description="Artículos sobre desarrollo web front-end, Astro, rendimiento y SEO técnico. Notas de lo que aprendo construyendo interfaces."
>
	<BlogNav />

	<main class="blog-cats" id="inicio">
		<header class="blog-hero reveal">
			<span class="eyebrow">Blog · Notas de desarrollo</span>
			<h1 class="blog-title">
				<span>Escribo sobre</span>
				<em>front-end</em>
			</h1>
			<p class="blog-intro">
				Desarrollo web, rendimiento y <em>SEO técnico</em>. Elige una sección
				para explorar, o entra a verlo todo.
			</p>
		</header>

		{posts.length === 0 ? (
			<p class="blog-empty">Pronto publicaré el primer artículo. Vuelve dentro de poco.</p>
		) : (
			<div class="cat-bento">
				{bento.map((t, i) => (
					<div class={`cat-cell ${t.featured ? "cell--featured" : "cell--sm"} reveal reveal-delay-${i + 1}`}>
						<CategoryTile cat={t.cat} label={t.label} count={t.count} featured={t.featured} />
					</div>
				))}
			</div>
		)}
	</main>

	<Footer />
</Layout>

<style>
	.blog-cats {
		width: min(1280px, 100% - 3rem);
		margin: 0 auto;
		min-height: 100svh;
		display: flex;
		flex-direction: column;
		padding: 8.5rem 0 3rem;
		position: relative;
		z-index: 5;
	}

	.blog-hero {
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
		margin-bottom: 2rem;
	}
	.blog-title {
		margin: 0.3rem 0 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(2.6rem, 7vw, 5rem);
		line-height: 0.9;
		letter-spacing: -0.03em;
		color: var(--text);
	}
	.blog-title span { display: inline; }
	.blog-title em {
		font-style: italic;
		color: var(--acid);
	}
	.blog-intro {
		font-size: 1rem;
		line-height: 1.6;
		color: var(--text-dim);
		margin: 0;
		max-width: 52ch;
	}
	.blog-intro em {
		font-style: italic;
		color: var(--text);
	}
	.blog-empty {
		font-family: var(--font-mono);
		font-size: 0.95rem;
		color: var(--text-dim);
	}

	/* Bento de categorías: ocupa el alto restante de la pantalla */
	.cat-bento {
		flex: 1;
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		grid-auto-rows: minmax(190px, 1fr);
		grid-auto-flow: dense;
		gap: 1.1rem;
	}
	.cat-cell { min-width: 0; }
	.cell--featured {
		grid-column: span 2;
		grid-row: span 2;
	}
	.cell--sm {
		grid-column: span 1;
	}

	@media (max-width: 980px) {
		.cat-bento {
			grid-template-columns: repeat(2, 1fr);
			grid-auto-rows: minmax(170px, 1fr);
		}
		.cell--featured {
			grid-column: span 2;
			grid-row: span 1;
		}
	}
	@media (max-width: 640px) {
		.blog-cats { padding: 6.5rem 0 2.5rem; }
		.cat-bento {
			grid-template-columns: 1fr;
			grid-auto-rows: minmax(30svh, auto);
			gap: 0.8rem;
		}
		.cell--featured { grid-row: span 1; }
	}
</style>
