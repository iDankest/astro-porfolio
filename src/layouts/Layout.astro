---
import CommandPalette from '../components/CommandPalette.astro';
import Preferences from '../components/Preferences.astro';

interface Props {
	title?: string;
	description?: string;
	type?: "website" | "article";
	image?: string;
	publishedDate?: string | null;
	modifiedDate?: string | null;
	tags?: string[];
	section?: string;
	wordCount?: number;
	readingMinutes?: number;
}

const {
	title = "Kilian Sánchez — Desarrollador Web Front-End",
	description = "Portfolio de Kilian Sánchez, desarrollador web front-end en Canarias. Interfaces atractivas, funcionales y con atención al detalle.",
	type = "website",
	image,
	publishedDate,
	modifiedDate,
	tags = [],
	section,
	wordCount,
	readingMinutes,
} = Astro.props;

const isArticle = type === "article";

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site) : new URL('/og.png', Astro.site);

const published = publishedDate ? new Date(publishedDate).toISOString() : undefined;
const modified = modifiedDate ? new Date(modifiedDate).toISOString() : published;

const graph: Record<string, any>[] = [
	{
		"@type": "Person",
		"@id": "https://idankest.dev/#person",
		name: "Kilian Sánchez",
		jobTitle: "Desarrollador Web Front-End",
		url: "https://idankest.dev/",
		image: new URL('/og.png', Astro.site).href,
		sameAs: [
			"https://github.com/idankest",
			"https://www.linkedin.com/in/dankest/",
		],
		address: {
			"@type": "PostalAddress",
			addressRegion: "Canarias",
			addressCountry: "ES",
		},
		knowsAbout: ["Vue.js", "React", "JavaScript", "TypeScript", "Astro", "Tailwind CSS", "Node.js", "PHP", "Symfony"],
	},
	{
		"@type": "WebSite",
		"@id": "https://idankest.dev/#website",
		url: "https://idankest.dev/",
		name: "Kilian Sánchez — Desarrollador Web Front-End",
		description,
		inLanguage: "es",
		publisher: { "@id": "https://idankest.dev/#person" },
	},
];

if (isArticle) {
	graph.push({
		"@type": "BlogPosting",
		"@id": canonical.href + "#article",
		headline: title,
		description,
		image: ogImage.href,
		datePublished: published,
		dateModified: modified,
		author: { "@id": "https://idankest.dev/#person" },
		publisher: { "@id": "https://idankest.dev/#person" },
		mainEntityOfPage: canonical.href,
		inLanguage: "es",
		keywords: tags.join(", "),
		...(section ? { articleSection: section } : {}),
		...(wordCount ? { wordCount } : {}),
		...(readingMinutes ? { timeRequired: `PT${readingMinutes}M` } : {}),
	});
	graph.push({
		"@type": "BreadcrumbList",
		"@id": canonical.href + "#breadcrumb",
		itemListElement: [
			{ "@type": "ListItem", position: 1, name: "Inicio", item: "https://idankest.dev/" },
			{ "@type": "ListItem", position: 2, name: "Blog", item: "https://idankest.dev/blog/" },
			{ "@type": "ListItem", position: 3, name: title, item: canonical.href },
		],
	});
}

const jsonLd = JSON.stringify({
	"@context": "https://schema.org",
	"@graph": graph,
});
---

<!DOCTYPE html>
<html lang="es">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">

	<script is:inline>
		// Aplica las preferencias (tema/animaciones/cursor) antes del primer paint.
		(function () {
			try {
				var root = document.documentElement;
				var t = localStorage.getItem('pref-theme') || 'dark';
				var prefersLight = matchMedia('(prefers-color-scheme: light)').matches;
				root.dataset.theme = t === 'system' ? (prefersLight ? 'light' : 'dark') : t;
				if (localStorage.getItem('pref-motion') === 'off') root.dataset.motion = 'off';
				if (localStorage.getItem('pref-cursor') === 'off') root.dataset.cursor = 'off';
			} catch (e) {}
		})();
	</script>

	<meta name="description" content={description}>
	<meta name="author" content="Kilian Sánchez">
	<meta name="theme-color" content="#0a0a0c">
	<link rel="canonical" href={canonical}>
	<link rel="alternate" type="application/rss+xml" title="Kilian Sánchez — Blog" href="/rss.xml">

	<meta property="og:title" content={title}>
	<meta property="og:description" content={description}>
	<meta property="og:type" content={type}>
	<meta property="og:url" content={canonical}>
	<meta property="og:site_name" content="Kilian Sánchez">
	<meta property="og:locale" content="es_ES">
	<meta property="og:image" content={ogImage}>
	<meta property="og:image:width" content="1200">
	<meta property="og:image:height" content="630">
	<meta property="og:image:alt" content="Kilian Sánchez — Desarrollador Web Front-End">

	{isArticle && (
		<>
			{published && <meta property="article:published_time" content={published} />}
			{modified && <meta property="article:modified_time" content={modified} />}
			<meta property="article:author" content="Kilian Sánchez" />
			{tags.map((t) => (
				<meta property="article:tag" content={t} />
			))}
		</>
	)}

	<meta name="twitter:card" content="summary_large_image">
	<meta name="twitter:title" content={title}>
	<meta name="twitter:description" content={description}>
	<meta name="twitter:image" content={ogImage}>

	<script type="application/ld+json" set:html={jsonLd}></script>

	<link rel="icon" type="image/svg+xml" href="/Code.svg">

	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&family=Manrope:wght@300;400;500;600;700&display=swap">

	<title>{title}</title>
	<style is:global>
		.scroll-progress {
			position: fixed;
			top: 0;
			left: 0;
			height: 2px;
			background: linear-gradient(90deg, var(--acid), var(--ember));
			width: 0%;
			z-index: 9999;
			pointer-events: none;
			transition: width 0.1s linear;
			box-shadow: 0 0 10px var(--acid-soft);
		}

		/* ===== Transición breve al entrar al blog ===== */
		.blog-transition {
			position: fixed;
			inset: 0;
			z-index: 10000;
			background: var(--ink);
			display: grid;
			place-items: center;
			pointer-events: none;
			visibility: hidden;
			transform: translateY(100%);
		}
		.blog-transition.active {
			visibility: visible;
			transform: translateY(0);
			transition: transform 0.5s var(--ease-out-expo);
		}
		.bt-inner {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 0.7rem;
			text-align: center;
			padding: 0 1.5rem;
		}
		.bt-eyebrow {
			font-family: var(--font-mono);
			font-size: 11px;
			letter-spacing: 0.28em;
			text-transform: uppercase;
			color: var(--text-dim);
			opacity: 0;
		}
		.bt-word-mask {
			overflow: hidden;
			padding: 0 0.08em 0.06em;
		}
		.bt-word {
			display: block;
			font-family: var(--font-display);
			font-style: italic;
			font-size: clamp(2.8rem, 11vw, 6.5rem);
			line-height: 1;
			letter-spacing: -0.02em;
			color: var(--text);
			transform: translateY(115%);
			white-space: nowrap;
		}
		.bt-word em {
			font-style: italic;
			color: var(--acid);
		}
		.bt-line {
			width: clamp(120px, 22vw, 240px);
			height: 2px;
			background: var(--acid);
			box-shadow: 0 0 14px var(--acid-soft);
			transform: scaleX(0);
			transform-origin: left center;
		}
		/* Sentido inverso: volver al portfolio (cortina desde arriba, línea desde la derecha) */
		.blog-transition.is-back {
			transform: translateY(-100%);
		}
		.blog-transition.is-back.active {
			transform: translateY(0);
		}
		.blog-transition.is-back .bt-line {
			transform-origin: right center;
		}
		.blog-transition.active .bt-eyebrow {
			animation: bt-fade 0.5s var(--ease-out-expo) 0.06s forwards;
		}
		.blog-transition.active .bt-word {
			animation: bt-rise 0.6s var(--ease-out-expo) 0.12s forwards;
		}
		.blog-transition.active .bt-line {
			animation: bt-line 0.55s var(--ease-out-expo) 0.3s forwards;
		}
		@keyframes bt-rise {
			to { transform: translateY(0); }
		}
		@keyframes bt-fade {
			from { opacity: 0; transform: translateY(8px); }
			to { opacity: 1; transform: translateY(0); }
		}
		@keyframes bt-line {
			to { transform: scaleX(1); }
		}
		@media (prefers-reduced-motion: reduce) {
			.blog-transition { display: none !important; }
		}
	</style>
</head>
	<body>
	<div class="scroll-progress" id="scrollProgress" aria-hidden="true"></div>
	<div class="cursor-dot" id="cursorDot"></div>
	<div class="cursor-ring" id="cursorRing"></div>

	<div class="blog-transition" id="blogTransition" aria-hidden="true">
		<div class="bt-inner">
			<span class="bt-eyebrow" id="btEyebrow">Entrando al</span>
			<span class="bt-word-mask"><span class="bt-word" id="btWord">Blog<em>.</em></span></span>
			<span class="bt-line"></span>
		</div>
	</div>

	<CommandPalette />
	<Preferences />

	<slot />

	<script>
		// Cursor custom solo en dispositivos con puntero fino y sin reduced-motion
		const wantsCursor =
			window.matchMedia('(hover: hover) and (pointer: fine)').matches &&
			!window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		const dot = document.getElementById('cursorDot');
		const ring = document.getElementById('cursorRing');

		if (wantsCursor && dot && ring) {
			let mx = 0, my = 0;
			let rx = 0, ry = 0;

			document.addEventListener('mousemove', (e) => {
				mx = e.clientX;
				my = e.clientY;
				dot.style.transform = `translate(${mx}px, ${my}px) translate(-50%, -50%)`;
			});

			function tick() {
				rx += (mx - rx) * 0.15;
				ry += (my - ry) * 0.15;
				ring.style.transform = `translate(${rx}px, ${ry}px) translate(-50%, -50%)`;
				requestAnimationFrame(tick);
			}
			tick();

			// Hide cursor on leave
			document.addEventListener('mouseleave', () => {
				dot.style.opacity = '0';
				ring.style.opacity = '0';
			});
			document.addEventListener('mouseenter', () => {
				dot.style.opacity = '1';
				ring.style.opacity = '1';
			});

			// Hover effect
			const hoverables = document.querySelectorAll('a, button, [data-cursor="hover"]');
			hoverables.forEach(el => {
				el.addEventListener('mouseenter', () => {
					ring.style.width = '60px';
					ring.style.height = '60px';
					ring.style.borderColor = '#c8ff00';
				});
				el.addEventListener('mouseleave', () => {
					ring.style.width = '36px';
					ring.style.height = '36px';
					ring.style.borderColor = '#f5f1e8';
				});
			});
		}

		// Scroll progress bar
		const scrollProgress = document.getElementById('scrollProgress');
		window.addEventListener('scroll', () => {
			const scrollTop = window.scrollY;
			const docHeight = document.documentElement.scrollHeight - window.innerHeight;
			const progress = (scrollTop / docHeight) * 100;
			scrollProgress.style.width = `${progress}%`;
		}, { passive: true });
	</script>

	<script>
		// Transición breve entre el portfolio y el blog (en ambos sentidos)
		const routeOverlay = document.getElementById('blogTransition');
		const rtWord = document.getElementById('btWord');
		const rtEyebrow = document.getElementById('btEyebrow');
		const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		if (routeOverlay && rtWord && rtEyebrow && !reduceMotion) {
			document.addEventListener('click', (e) => {
				if (e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;

				const target = e.target;
				const link = target instanceof Element ? target.closest('a') : null;
				if (!(link instanceof HTMLAnchorElement)) return;
				if (link.target === '_blank') return;

				let url;
				try {
					url = new URL(link.href, location.href);
				} catch {
					return;
				}
				if (url.origin !== location.origin) return;
				if (url.pathname === location.pathname) return;

				const onBlog = location.pathname.startsWith('/blog');
				const toBlog = url.pathname.startsWith('/blog');
				const toHome = url.pathname === '/';

				let label, eyebrow, back;
				if (toBlog && !onBlog) {
					label = 'Blog';
					eyebrow = 'Entrando al';
					back = false;
				} else if (onBlog && toHome) {
					label = 'Portfolio';
					eyebrow = 'Volviendo al';
					back = true;
				} else {
					return; // dentro de la misma sección: sin cortina
				}

				e.preventDefault();
				rtEyebrow.textContent = eyebrow;
				rtWord.innerHTML = label + '<em>.</em>';
				routeOverlay.classList.toggle('is-back', back);
				void routeOverlay.offsetWidth; // reflow: fija la posición inicial antes de animar
				routeOverlay.classList.add('active');
				window.setTimeout(() => {
					window.location.href = url.href;
				}, 760);
			});
		}
	</script>
</body>
</html>
