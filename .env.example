# Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Email donde recibirás los mensajes del formulario
CONTACT_EMAIL=dankestmirror@hotmail.es

# Dirección desde la que se envían los correos.
# Por defecto usa el remitente de testing de Resend (no requiere verificar dominio).
# Para producción, verifica tu dominio en Resend y usa algo como:
# FROM_EMAIL=Kilian Sánchez <hola@idankest.dev>
FROM_EMAIL=onboarding@resend.dev

# Nombre que aparece en el auto-reply
FROM_NAME=Kilian Sánchez

# ============================================================================
# BLOG · Keystatic + repo de contenido privado
# ============================================================================

# Token de lectura del repo privado `iDankest/blog-content`, usado por el
# reader en build (SSG) para generar /blog. Fine-grained PAT con permiso
# "Contents: Read-only" sobre ese repo. SOLO en producción (Netlify).
# En local sin este valor, el blog se lee de la carpeta `posts/`.
GITHUB_PAT=github_pat_xxxxxxxxxxxxxxxxxxxx

# Credenciales del panel de edición (idankest.dev/keystatic) en GitHub mode.
# Se generan automáticamente al dar de alta la GitHub App desde /keystatic.
# Definir estas 4 en Netlify (no en local; en local el panel usa storage local).
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
